# ARGUS Backend — example env (copy to .env)
# See docs for full reference

# Database
DATABASE_URL=postgresql+asyncpg://argus:argus@localhost:5432/argus

# Tenant isolation (RLS) — default tenant for MVP without auth
# Must match a tenant.id in DB. Create default tenant in migration if needed.
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# LLM Providers (Phase 6) — AI Orchestrator
# At least one LLM key enables AI orchestration for anomaly analysis, hypothesis generation, and threat assessment.
# If none set, system falls back to rule-based analysis (no AI features).

OPENROUTER_API_KEY=
KIMI_API_KEY=
PERPLEXITY_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=

# Intel adapters (Phase 6 / INT-001) — optional, skip when not set
# Used for passive intelligence gathering: domain enumeration, vulnerability data, IP reputation, etc.
# Each service can be enabled independently; missing keys are silently skipped.

# Shodan — IP/port/service enumeration, CVE lookup by banner
SHODAN_API_KEY=

# GitHub — public repositories, code leaks, exposed credentials
GITHUB_TOKEN=

# Censys — SSL certificates, host enumeration, internet-wide scanning database
CENSYS_API_KEY=

# SecurityTrails — DNS history, domain/subdomain enumeration, passive DNS
SECURITYTRAILS_API_KEY=

# VirusTotal — URL/file reputation, malware analysis, threat intelligence
VIRUSTOTAL_API_KEY=

# AbuseIPDB — IP reputation, malicious activity reports
ABUSEIPDB_API_KEY=

# GreyNoise — sensor network, internet background noise, attack detection
GREYNOISE_API_KEY=

# OTX (AlienVault) — open threat exchange, indicators of compromise
OTX_API_KEY=

# URLscan.io — website screenshot, DOM inspection, security indicators
URLSCAN_API_KEY=

# ExploitDB — public exploits, vulnerability database
EXPLOITDB_API_KEY=

# Auth (Phase 2+)
# Required for POST /auth/login. Dev placeholder; use openssl rand -hex 32 in production
JWT_SECRET=dev-secret-change-in-prod-32chars

# Admin API — when set, /api/v1/admin/* requires X-Admin-Key header
ADMIN_API_KEY=
JWT_EXPIRY=15m
JWT_ALGORITHM=HS256

# ---------------------------------------------------------------------------
# ISS-T20-003 Phase 1 (B6-T08) — bcrypt admin + CSPRNG cookie session.
# ---------------------------------------------------------------------------
# ADMIN_AUTH_MODE picks the gate enforced by `require_admin`:
#   * cookie  — legacy `X-Admin-Key` shim only (pre-Phase-1 behaviour);
#   * session — new `argus.admin.session` cookie / Bearer flow only;
#   * both    — try the session cookie first, fall back to `X-Admin-Key`.
# Default is `both` so existing operator tooling keeps working during the
# migration window. Switch to `session` once the frontend (B6-T09) ships
# the cookie-based login flow and you have rotated all operator passwords.
ADMIN_AUTH_MODE=both
# Sliding-window session lifetime in seconds (default 12h). Each request
# that hits `resolve_session` extends `last_used_at` and `expires_at`.
ADMIN_SESSION_TTL_SECONDS=43200
# Per-IP login-rate-limit (token bucket, default 10 req/min/IP). The
# limiter responds with HTTP 429 + `Retry-After` so brute-force tooling
# backs off; tighten in production once the legitimate operator volume
# is known.
ADMIN_LOGIN_RATE_LIMIT_PER_MINUTE=10
# ISS-T20-003 hardening (Alembic 030) — server-side HMAC key used to hash
# the session id at rest:
#   session_token_hash = HMAC-SHA256(ADMIN_SESSION_PEPPER, raw_token)
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Defeats replay-from-DB-leak: a stolen DB dump cannot be turned into a valid
# bearer cookie without the (server-only) pepper. When unset AND
# ADMIN_AUTH_MODE in {session, both}, session-mode logins refuse and the
# resolver returns None; cookie-mode keeps working as the fail-safe so a
# forgotten config knob never bricks admin access entirely.
#
# Rotation procedure (security-critical):
#   Changing ADMIN_SESSION_PEPPER invalidates every existing
#   `session_token_hash` because HMAC(OLD_PEPPER, raw) != HMAC(NEW_PEPPER, raw).
#   Since C7-T07 / Alembic 031 removed the raw `session_id` mirror column,
#   rotation is now strictly invalidating — there is no zero-downtime path
#   without a dual-pepper accepter (planned in ISS-T20-003 Phase 2).
#   Procedure (full runbook in docs/operations/admin-sessions.md §5):
#     1. Stage the new value in the secrets store.
#     2. (Optional but recommended) Pre-revoke all live sessions so the
#        cutover is instantaneous instead of staggered:
#          UPDATE admin_sessions SET revoked_at = NOW()
#          WHERE revoked_at IS NULL AND expires_at > NOW();
#     3. Roll the backend (`kubectl rollout restart deploy/argus-backend`).
#     4. Verify a fresh login produces a `session_token_hash` that matches
#        what the new pepper computes (see runbook §5.3 step 5).
#     5. Drop the previous pepper from the secrets store after the
#        maintenance window closes so a botched rollback cannot resurrect
#        it.
ADMIN_SESSION_PEPPER=
# REMOVED in Cycle 7 / C7-T07 (ISS-T20-003 Phase 2c) — the
# ADMIN_SESSION_LEGACY_RAW_WRITE / ADMIN_SESSION_LEGACY_RAW_FALLBACK
# grace-window toggles were dropped together with Alembic 031, which
# removes the legacy `admin_sessions.session_id` column and promotes
# `session_token_hash` to the sole primary key. Setting either env
# variable now is a no-op (Pydantic ignores unknown env keys); the
# resolver looks up sessions by HMAC hash exclusively. Sessions minted
# before Alembic 030 are unreachable post-031 and must be re-issued.
# Optional bootstrap admin — materialised idempotently on app startup
# (see `bootstrap_admin_user_if_configured`). The password hash MUST be a
# pre-computed bcrypt digest (rounds >= 12), generated out-of-band via
# the operator runbook (e.g. `python -c "from passlib.hash import bcrypt;
# print(bcrypt.using(rounds=12).hash('<plaintext>'))"`). PLAINTEXT IS
# NEVER ACCEPTED, never logged, and never written to disk by the
# bootstrap path.
ADMIN_BOOTSTRAP_SUBJECT=
ADMIN_BOOTSTRAP_PASSWORD_HASH=
# Role for the bootstrap admin (`operator` | `admin` | `super-admin`).
ADMIN_BOOTSTRAP_ROLE=super-admin
# Optional tenant scope for the bootstrap admin. Leave empty for
# super-admin (cross-tenant); set to a tenant UUID for tenant-scoped
# operator accounts.
ADMIN_BOOTSTRAP_TENANT_ID=

# ---------------------------------------------------------------------------
# Cycle 7 / C7-T01 — Admin MFA (TOTP + backup codes; ISS-T20-003 Phase 2a)
# ---------------------------------------------------------------------------
# ADMIN_MFA_KEYRING is a CSV of base64 Fernet keys, NEWEST FIRST. The first
# key encrypts new TOTP secrets; the rest decrypt older ones. Empty =
# admin-MFA layer disabled (acceptable in dev; fatal in production once
# any admin is enrolled — the DAO refuses to load with no keyring).
#
# Generate one Fernet key (Python):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Rotation cookbook:
#   1) Generate a fresh key with the snippet above.
#   2) Prepend it to ADMIN_MFA_KEYRING (must remain newest-first).
#   3) Deploy. Existing secrets keep decrypting with the old (now second)
#      key; new enrolments and verify-time re-encryptions use the new key.
#   4) After ≥ 90 days (so every active admin has logged in and triggered
#      opportunistic re-encryption), drop the oldest key from the CSV.
ADMIN_MFA_KEYRING=
# Re-auth window for sensitive admin endpoints, in seconds. 12 h matches
# ADMIN_SESSION_TTL_SECONDS so MFA is re-prompted at most once per session.
ADMIN_MFA_REAUTH_WINDOW_SECONDS=43200
# CSV of admin roles for which MFA is mandatory at the policy layer.
# Default mirrors the most-privileged role only; broaden gradually as
# enrolment workflows roll out (C7-T03 / C7-T04). Accepts both the
# canonical hyphen form (super-admin) and the underscore form
# (super_admin); both normalise to "super-admin".
ADMIN_MFA_ENFORCE_ROLES=super-admin
# ---------------------------------------------------------------------------

# DEBUG=true: verbose diagnostics; with no explicit CORS origins, allows localhost dev defaults when CORS_INCLUDE_DEV_ORIGINS is true
DEBUG=false
# When true (default), merge localhost dev URLs into CORS; when the effective origin list is empty (* or unset CORS_ORIGINS), dev defaults apply only if DEBUG or this is true
CORS_INCLUDE_DEV_ORIGINS=true

# CORS
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO

# OWASP-001 — путь к JSON с русскими описаниями OWASP Top 10:2025 (относительно корня backend или абсолютный)
# OWASP_JSON_PATH=data/owasp_top_10_2025_ru.json

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
# Required for Celery; defaults to REDIS_URL if empty
CELERY_BROKER_URL=redis://localhost:6379/0

# MinIO/S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=argus
MINIO_SECRET_KEY=argussecret
MINIO_BUCKET=argus
# Generated report files (PDF/HTML/JSON/CSV cache); presigned URLs point here
MINIO_REPORTS_BUCKET=argus-reports
MINIO_SECURE=false

# Sandbox
SANDBOX_ENABLED=true

# KAL-003 — multi-phase nmap in recon when SANDBOX_ENABLED=true and KAL network_scanning argv policy allows baseline -sS scan
# NMAP_RECON_CYCLE=false disables the cycle (falls back to single local nmap -sV -sC).
# NMAP_FULL_TCP=true adds -p- -sV -O; NMAP_UDP_TOP50=true adds UDP top 50; NMAP_RECON_PHASE_TIMEOUT_SEC caps each phase (seconds).
# NMAP_RECON_CYCLE=true
# NMAP_FULL_TCP=false
# NMAP_UDP_TOP50=false
# NMAP_RECON_PHASE_TIMEOUT_SEC=600

# KAL-006 — searchsploit from recon service/version strings (bounded by SEARCHSPLOIT_MAX_QUERIES)
# SEARCHSPLOIT_ENABLED=true
# SEARCHSPLOIT_MAX_QUERIES=8
# Optional Trivy fs scan when recon uploaded dependency_requirements_txt / dependency_package_json artifacts
# TRIVY_ENABLED=false
# Reporting: Pwned Passwords k-anonymity API (never logs full password); explicit consent required
# HIBP_PASSWORD_CHECK_OPT_IN=false

# === Stage 4: Exploitation ===
# MinIO bucket for exploitation artifacts (plans, results, shell logs)
STAGE4_ARTIFACTS_BUCKET=stage4-artifacts
# Max duration (minutes) for a single exploitation run before timeout
EXPLOITATION_TIMEOUT_MINUTES=10
# Max concurrent exploitation runs across all engagements
EXPLOITATION_MAX_CONCURRENT=3
# Minutes to wait for manual approval before auto-expiring an exploitation request
EXPLOITATION_APPROVAL_TIMEOUT_MINUTES=60

# VA active scan / MCP sandbox (OWASP-002) — max concurrent async tool runs; stdout/stderr cap per stream
ACTIVE_SCAN_MAX_CONCURRENT_JOBS=3
ACTIVE_SCAN_MAX_CAPTURE_BYTES=4194304
# VA-002 — when true, append LLM-suggested scanner argv after deterministic plan (requires LLM API keys)
VA_AI_PLAN_ENABLED=false
# VA-007 — exploitation phase may enqueue Celery sqlmap for SQLi-like findings (requires SQLMAP_VA_ENABLED + policy)
VA_EXPLOIT_AGGRESSIVE_ENABLED=false
# OWASP-004 — enable sqlmap in VA / aggressive exploit enqueue
SQLMAP_VA_ENABLED=false
# Merge aggressive argv from backend/data/tool_configs.json (false = stable argv for CI/tests; true for louder XSS/SQLi scans).
# When true, also expands custom reflected-XSS PoC (more payloads, cap 80) — useful for alf.nu-style script-context challenges.
# VA_AGGRESSIVE_SCAN=true
VA_AGGRESSIVE_SCAN=false
# Reflected XSS httpx probe after VA active scan (payloads: data/payloads/xss_custom.txt)
VA_CUSTOM_XSS_POC_ENABLED=true
# XSS-006 (src.core.config): Playwright XSS verification + optional remote payload JSON (same names as infra/.env.example).
# XSS_VERIFICATION_ENABLED — headless Playwright XSS verification (Settings.xss_verification_enabled).
XSS_VERIFICATION_ENABLED=true
# XSS_PLAYWRIGHT_TIMEOUT — Playwright timeout in ms (alias XSS_PLAYWRIGHT_TIMEOUT_MS; Settings.xss_playwright_timeout_ms).
XSS_PLAYWRIGHT_TIMEOUT=5000
# XSS_PAYLOAD_COLLECTION_URL — optional URL returning JSON array of payloads merged into buckets (empty = off).
XSS_PAYLOAD_COLLECTION_URL=

# =============================================================================
# Backend MCP server (Backlog/dev1_md §13 — `python -m src.mcp.server`)
# Exposes 15 tools / 4 resources / 3 prompts to MCP-compatible LLM clients
# (Cursor, Claude Desktop, OpenAI Responses) over stdio (default) or HTTP.
# =============================================================================
# Transport: stdio (default; for IDE / CLI clients) | streamable-http | sse
MCP_TRANSPORT=stdio
# Bind host / port for HTTP transports — loopback by default.
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8765
# Display name & log level
MCP_SERVER_NAME=argus
MCP_LOG_LEVEL=INFO
# Static bearer token accepted on every transport. Generate: openssl rand -hex 32.
# Required for production HTTP/SSE; the stdio fallback only kicks in when
# MCP_TRANSPORT=stdio AND no bearer / API-key headers are present.
MCP_AUTH_TOKEN=
# Force authentication on every call regardless of transport. Default: true
# for HTTP/SSE, false for stdio.
MCP_REQUIRE_AUTH=false
# Default tenant attached to anonymous stdio sessions (must be a valid UUID
# resolvable by the policy plane).
MCP_STDIO_TENANT_ID=00000000-0000-0000-0000-000000000001
# Audit-log actor id used when stdio fallback kicks in.
MCP_STDIO_ACTOR_ID=local-stdio
# Path to the signed MCP server config (verified at server boot via mcp_sign).
MCP_CONFIG_PATH=backend/config/mcp/server.yaml
MCP_CONFIG_SIGNATURES_PATH=backend/config/mcp/SIGNATURES
MCP_CONFIG_KEYS_DIR=backend/config/mcp/_keys

# Legacy ARGUS MCP — future HTTP/SSE transport (reserved). Stage 1 endpoint
# discovery uses mcp-server-fetch (pip) for HTTP fetch, not ARGUS MCP.
ARGUS_MCP_HTTP_URL=

# RECON-002 — passive subdomain enumeration (see infra .env.example for full RECON_* block)
# RECON_PASSIVE_SUBDOMAIN_TIMEOUT_SEC=
# RECON_THEHARVESTER_SOURCES=crtsh,anubis,urlscan
# RECON_THEHARVESTER_RECON_LIMIT=300
# RECON_THEHARVESTER_PASSIVE_ENABLED=true

# RECON-003 — dnsx multi-record probe + optional dig ANY + dns_records.json / raw in MinIO (recon/raw)
# RECON_DNS_DEPTH_ENABLED=true
# RECON_DNS_DEPTH_DIG_DEEP=false
# RECON_DNS_DEPTH_TAKEOVER_HINTS=true
# RECON_DNSX_RECORD_TYPES=a,aaaa,cname,mx,txt,ns
# RECON_DNSX_INCLUDE_RESP=false
# RECON_DNSX_SILENT=false
# RECON_DNS_DEPTH_TIMEOUT_SEC=
# RECON_DNSX_EXTRA_FLAGS=  # space-separated; allowlisted only (e.g. -silent -wd -resp -oc)

# RECON-004 — httpx / whatweb / nuclei tech-only recon (active & full); rate limit from RECON_RATE_LIMIT*
# RECON_NUCLEI_TECH_TAGS=tech
# RECON_NUCLEI_TECH_TEMPLATES=  # optional comma-separated nuclei -t entries (admin-controlled); if set, overrides tags when non-empty
# RECON-005 — deep port scan: naabu (optional) + nmap -sV on capped hosts/ports; only RECON_MODE=full and RECON_DEEP_PORT_SCAN=true
# RECON_DEEP_NAABU_ENABLED=true
# RECON_DEEP_NAABU_TOP_PORTS=500
# RECON_DEEP_MAX_HOSTS=5
# RECON_DEEP_MAX_PORTS_PER_HOST=40
# RECON_DEEP_TIMEOUT_SEC=  # falls back to RECON_TOOLS_TIMEOUT
#
# RECON-007 — query params + JS URLs (full + RECON_JS_ANALYSIS); linkfinder/unfurl via KAL policy category js_analysis
# RECON_JS_ANALYSIS=false
# RECON_JS_MAX_MERGED_URLS=20000
# RECON_JS_MAX_JS_URLS=200
# RECON_JS_MAX_DOWNLOADS=15
# RECON_JS_MAX_RESPONSE_BYTES=1048576
# RECON_JS_LINKFINDER_ENABLED=true
# RECON_JS_UNFURL_ENABLED=false
# RECON_JS_UNFURL_MAX_URLS=10
#
# RECON-008 — asnmap (apex ASN JSON summary) + gowitness screenshots (live URLs from httpx); full mode + flags; passive skips optional steps
# RECON_ASNMAP_ENABLED=true
# RECON_SCREENSHOTS=false
# RECON_GOWITNESS_MAX_URLS=25
# RECON_GOWITNESS_TIMEOUT_SEC=  # defaults to RECON_TOOLS_TIMEOUT
# RECON_GOWITNESS_CONCURRENCY=3

# ═══ ENH-V2: Enhancement Module Configuration ═══
# Multi-provider LLM routing: override primary provider for all tasks
# Options: deepseek, openai, openrouter, kimi, perplexity
LLM_PRIMARY_PROVIDER=deepseek

# Maximum LLM cost per scan (USD). Scan aborts if exceeded.
MAX_COST_PER_SCAN_USD=10.0

# Report language (ISO 639-1). AI sections will be generated in this language.
REPORT_LANGUAGE=ru

# Shodan enrichment: cross-reference findings with Shodan CVEs and service data
SHODAN_ENRICHMENT_ENABLED=true

# Perplexity web-search intelligence: CVE exploit search, domain OSINT
PERPLEXITY_INTEL_ENABLED=true

# Adversarial prioritization score: compute attack-realistic scoring
ADVERSARIAL_SCORE_ENABLED=true

# Exploitability validation: multi-stage LLM validation pipeline
EXPLOITABILITY_VALIDATION_ENABLED=true

# PoC generation: auto-generate proof-of-concept scripts for confirmed findings
POC_GENERATION_ENABLED=true

# ─── ENH-V3: Strix-based enhancements ───────────────────────────────

# Scan mode: quick (high-impact, ~15min) | standard (OWASP Top 10, ~45min) | deep (exhaustive, hours)
SCAN_MODE=standard

# LLM-based semantic deduplication of findings (Strix-style XML response)
LLM_DEDUP_ENABLED=true

# Memory compression for long-running scans (>40 LLM calls)
MEMORY_COMPRESSION_ENABLED=true
