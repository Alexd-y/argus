\fancyfoot[C]{\small\color{argusmuted}ARGUS Confidential — page \thepage{} of \pageref*{LastPage}}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

{# Jinja2's default comment delimiter is ``{# ... #}``; LaTeX's
   ``\newcolumntype{L}[1]{...p{#1}...}`` would otherwise be parsed as
   the start of a Jinja comment that swallows the rest of the document.
   Wrap the literal in ``{% raw %}`` to keep it intact. #}
{% raw %}\newcolumntype{L}[1]{>{\RaggedRight\arraybackslash}p{#1}}{% endraw %}

