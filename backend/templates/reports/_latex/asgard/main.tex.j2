{# ARG-058 / B6-T01 — In PDF/A-2u mode pdfx owns the /Info dictionary and
   XMP metadata stream (sourced from ``_preamble/pdfa.xmpdata.j2``). A
   subsequent ``\hypersetup{pdftitle=...}`` would silently override /Info,
   breaking XMP↔/Info equivalence (verapdf rule 6.7.3-1). Gate the block
   so the standard render path is byte-identical to the pre-ARG-058 output
   and the PDF/A path leaves pdfx as the single source of metadata truth. #}
{% if not pdfa_mode | default(false) %}
\hypersetup{
  pdftitle={ARGUS Security Posture Report — Asgard Tier},
  pdfauthor={ARGUS},
  pdfsubject={Security assessment report (Tier 2 — operator brief)},
  pdfcreator={ARGUS Cycle 5},
  pdfproducer={LaTeX (xelatex/pdflatex via latexmk)}
}
{% endif %}

