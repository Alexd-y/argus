<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ARGUS Report — {{ recon_summary.target_url or scan_id or "scan" }}</title>
    <style>
        body { font-family: system-ui, sans-serif; max-width: 960px; margin: 2rem auto; padding: 0 1rem; color: #1a1a2e; }
        h1 { color: #1a1a2e; }
        h2 { margin-top: 1.75rem; font-size: 1.15rem; border-bottom: 1px solid #e0e0e0; padding-bottom: 0.35rem; }
        h3 { font-size: 0.95rem; margin: 0.75rem 0 0.35rem; color: #444; }
        .meta { color: #555; font-size: 0.9rem; margin-bottom: 1.5rem; }
        .tier-badge { display: inline-block; padding: 0.2rem 0.55rem; border-radius: 4px; background: #eef2ff; font-size: 0.8rem; text-transform: capitalize; }
        table { width: 100%; border-collapse: collapse; margin-top: 0.5rem; }
        th, td { border: 1px solid #ddd; padding: 0.5rem 0.65rem; text-align: left; vertical-align: top; }
        th { background: #f5f5f5; }
        td.desc { white-space: pre-wrap; word-break: break-word; }
        .sev-critical { color: #c00; font-weight: bold; }
        .sev-high { color: #e67e22; font-weight: bold; }
        .sev-medium { color: #f39c12; }
        .sev-low { color: #27ae60; }
        .sev-info { color: #3498db; }
        .panel { margin-top: 1.25rem; padding: 1rem; background: #f8f9fa; border-radius: 6px; }
        .ai-slot-body { margin: 0.25rem 0 0.75rem; white-space: normal; word-break: break-word; }
        .ai-slot-body h1, .ai-slot-body h2, .ai-slot-body h3, .ai-slot-body h4 {
            margin-top: 0.8em; margin-bottom: 0.4em;
        }
        .ai-slot-body ul, .ai-slot-body ol {
            margin-left: 1.5em; margin-bottom: 0.5em;
        }
        .ai-slot-body p { margin-bottom: 0.5em; }
        .ai-slot-body code {
            background: #f4f4f4; padding: 0.1em 0.3em; border-radius: 3px; font-size: 0.9em;
        }
        ul.timeline { margin: 0.35rem 0 0 1.25rem; }
        .empty { color: #777; font-style: italic; }
        .owasp-compliance { margin: 1rem 0 1.25rem; }
        .owasp-compliance-heading { font-size: 1rem; margin: 0 0 0.5rem; color: #333; border-bottom: none; }
        .owasp-compliance-table { margin-top: 0.35rem; font-size: 0.9rem; }
        .owasp-compliance-table th.owasp-compliance-count-col { text-align: center; width: 8rem; }
        .owasp-compliance-table td.owasp-compliance-presence { text-align: center; font-weight: 600; }
        tr.owasp-compliance-0 td.owasp-compliance-presence { background: #e8f5e9; color: #1b5e20; }
        tr.owasp-compliance-warn td.owasp-compliance-presence { background: #fff8e1; color: #e65100; }
        tr.owasp-compliance-high td.owasp-compliance-presence { background: #ffebee; color: #b71c1c; }
        .owasp-finding-cell { font-size: 0.9rem; }
        .owasp-finding-label { color: #444; }
        /* Valhalla — wide findings table + PoC sub-rows (WeasyPrint) */
        .valhalla-findings .findings-main-table { font-size: 0.8rem; table-layout: fixed; }
        .valhalla-findings .findings-main-table th:nth-child(4),
        .valhalla-findings .findings-main-table td.desc { word-break: break-word; overflow-wrap: anywhere; }
        .valhalla-findings .findings-main-table code { font-size: 0.85em; word-break: break-all; }
        .finding-poc { margin-top: 0.5rem; padding: 0.5rem 0; border-top: 1px solid #e8e8e8; }
        .finding-poc-title { font-size: 0.9rem; margin: 0 0 0.35rem; }
        .finding-poc-block { margin: 0.25rem 0; padding: 0.45rem 0.55rem; background: #fff; border: 1px solid #e0e0e0; border-radius: 4px; font-size: 0.78rem; white-space: pre-wrap; word-break: break-word; overflow-wrap: anywhere; }
        .finding-poc-screenshot-thumb img { display: block; margin-top: 0.35rem; }
    </style>
</head>
<body>
    <h1>ARGUS Security Report</h1>
    <p class="meta">
        <span class="tier-badge">{{ tier }}</span>
        {% set stub = tier_stubs.get(tier) %}
        {% if stub %}
            — {{ stub.label }} ({{ stub.focus }})
        {% endif %}
    </p>
    {% block recon %}
        {% include "partials/recon_summary.html.j2" %}
    {% endblock %}
    {% block findings %}
        {% include "partials/findings_table.html.j2" %}
    {% endblock %}
    {% block active_web_scan %}
        {% include "partials/active_web_scan.html.j2" %}
    {% endblock %}
    {% block artifacts %}
        {% include "partials/artifacts.html.j2" %}
    {% endblock %}
    {% block exploitation %}{% endblock %}
    {% block ai %}
        {% include "partials/ai_slots.html.j2" %}
    {% endblock %}
    {% block extra %}{% endblock %}
</body>
</html>
