<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ARGUS Report — {{ recon_summary.target_url or scan_id or "scan" }}</title>
    <style>
        body { font-family: system-ui, sans-serif; max-width: 960px; margin: 2rem auto; padding: 0 1rem; color: #1a1a2e; }
        h1 { color: #1a1a2e; }
        h2 { margin-top: 1.75rem; font-size: 1.15rem; border-bottom: 1px solid #e0e0e0; padding-bottom: 0.35rem; }
        h3 { font-size: 0.95rem; margin: 0.75rem 0 0.35rem; color: #444; }
        .meta { color: #555; font-size: 0.9rem; margin-bottom: 1.5rem; }
        .tier-badge { display: inline-block; padding: 0.2rem 0.55rem; border-radius: 4px; background: #eef2ff; font-size: 0.8rem; text-transform: capitalize; }
        table { width: 100%; border-collapse: collapse; margin-top: 0.5rem; }
        th, td { border: 1px solid #ddd; padding: 0.5rem 0.65rem; text-align: left; vertical-align: top; }
        th { background: #f5f5f5; }
        td.desc { white-space: pre-wrap; word-break: break-word; }
        .sev-critical { color: #c00; font-weight: bold; }
        .sev-high { color: #e67e22; font-weight: bold; }
        .sev-medium { color: #f39c12; }
        .sev-low { color: #27ae60; }
        .sev-info { color: #3498db; }
        .panel { margin-top: 1.25rem; padding: 1rem; background: #f8f9fa; border-radius: 6px; }
        .ai-slot-body { margin: 0.25rem 0 0.75rem; white-space: pre-wrap; word-break: break-word; }
        ul.timeline { margin: 0.35rem 0 0 1.25rem; }
        .empty { color: #777; font-style: italic; }
    </style>
</head>
<body>
    <h1>ARGUS Security Report</h1>
    <p class="meta">
        <span class="tier-badge">{{ tier }}</span>
        {% set stub = tier_stubs.get(tier) %}
        {% if stub %}
            — {{ stub.label }} ({{ stub.focus }})
        {% endif %}
    </p>
    {% block recon %}
        {% include "partials/recon_summary.html.j2" %}
    {% endblock %}
    {% block findings %}
        {% include "partials/findings_table.html.j2" %}
    {% endblock %}
    {% block active_web_scan %}
        {% include "partials/active_web_scan.html.j2" %}
    {% endblock %}
    {% block artifacts %}
        {% include "partials/artifacts.html.j2" %}
    {% endblock %}
    {% block exploitation %}{% endblock %}
    {% block ai %}
        {% include "partials/ai_slots.html.j2" %}
    {% endblock %}
    {% block extra %}{% endblock %}
</body>
</html>
