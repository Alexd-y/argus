{# Objectives, scope, and methodology #}
{% set opts = scan.options if scan and scan.options is mapping else {} %}
{% set vcm = valhalla_context if valhalla_context is defined else none %}
{% set target = recon_summary.target_url or (report.target if report else "") or (scan.target_url if scan else "") or "" %}
{% set obj = opts.get("object_text") or opts.get("scope_object") %}
{% set goal = opts.get("goal_text") or opts.get("pentest_goal") %}
{% set scope_in = opts.get("scope_in") or opts.get("scope_description") %}
{% set scope_out = opts.get("scope_out") or opts.get("out_of_scope") %}

<section class="valhalla-objectives panel" id="objectives">
    <h2>Subject, Goals and Objectives</h2>
    <p><strong>Subject:</strong> {% if obj %}{{ obj }}{% else %}Public web resource {{ target or "target not specified" }} and related components (if applicable).{% endif %}</p>
    <p><strong>Goal:</strong> {% if goal %}{{ goal }}{% else %}Assess evidence-backed security signals for the web resource {{ target or "target not specified" }} from an external perspective.{% endif %}</p>
    <p><strong>Objectives:</strong></p>
    <ul>
        {% if opts.get("tasks") and opts.get("tasks") is iterable and opts.get("tasks") is not string %}
            {% for t in opts.get("tasks") %}
                <li>{{ t }}</li>
            {% endfor %}
        {% else %}
            <li>Identify vulnerabilities in the web application and adjacent infrastructure.</li>
            <li>Assess authentication, authorization, and exposure signals within the tested scope.</li>
            <li>Provide recommendations for improving the security posture.</li>
        {% endif %}
    </ul>
</section>

<section class="valhalla-scope panel" id="scope">
    <h2>Scope and Limitations</h2>
    <h3>In Scope</h3>
    {% if scope_in %}
        <div class="ai-slot-body">{{ scope_in }}</div>
    {% else %}
        <ul>
            <li>Domains, subdomains, and IPs agreed upon for scanning: {{ target or "target not specified" }}.</li>
            <li>External perimeter and agreed entry points (URLs, forms, APIs if applicable).</li>
            <li>Non-destructive testing without DoS and without actions outside the agreed scope.</li>
        </ul>
    {% endif %}
    <h3>Out of Scope</h3>
    {% if scope_out %}
        <div class="ai-slot-body">{{ scope_out }}</div>
    {% else %}
        <p>Third-party systems and services not included in the agreed scope; third-party payment gateways — not tested unless separately agreed upon.</p>
    {% endif %}
</section>

<section class="valhalla-methodology panel" id="methodology">
    <h2>Methodology and Standards</h2>
    <h3>Standards and References Used</h3>
    <ul>
        <li>NIST SP 800-115 — Technical Guide to Information Security Testing and Assessment</li>
        <li>CWE — Common Weakness Enumeration (MITRE)</li>
        <li>OWASP Web Security Testing Guide (WSTG)</li>
        <li>OWASP ASVS; OWASP Top 10</li>
        <li>SANS CWE Top 25</li>
        <li>CVSS v3.1</li>
        <li>WASC, OSSTMM (including classes: HTTP pollution/tampering, Injection, XSS, Broken Authentication, CSRF, Security Misconfiguration, Insecure Cryptographic Storage, Failure to Restrict URL Access, Insufficient Transport Layer Protection, Unvalidated Redirects, IDOR, SSRF, XXE, supply chain analysis)</li>
    </ul>

    <h3>Test Types (WSTG-aligned)</h3>
    <p><strong>Information Gathering:</strong> domains/subdomains, technologies, entry points, ports and services. OSINT and technical information gathering performed per WSTG Information Gathering section.</p>
    <p><strong>Configuration and Deployment:</strong> HTTP methods, TLS/HTTPS, HSTS, security headers (CSP, X-Frame-Options, X-Content-Type-Options, etc.).</p>
    <p><strong>Authentication and Identity:</strong> login, password recovery, alternative authentication channels.</p>
    <p><strong>Authorization and Access:</strong> vertical/horizontal privilege escalation, IDOR, ACL, hidden admin interfaces.</p>
    <p><strong>Session Management:</strong> cookie flags, session fixation, logout, session lifetime.</p>
    <p><strong>Input Validation and Injection:</strong> SQL/NoSQL/Command injection, XSS, SSTI, path traversal, XXE.</p>
    <p><strong>Business Logic:</strong> workflow bypass, limits, roles.</p>
    <p><strong>Cryptography and Data:</strong> algorithms, keys, sensitive data in traffic/logs/cookies.</p>
    <p><strong>Client-Side:</strong> DOM XSS, SPA/PWA, localStorage/sessionStorage.</p>
    <p><strong>API (if applicable):</strong> REST/GraphQL — authZ, bulk, rate limiting, OWASP API Top 10.</p>

    <h3>Phases</h3>
    <ul>
        <li>Reconnaissance (OSINT, information gathering)</li>
        <li>Automated scanning</li>
        <li>Manual verification (PoC)</li>
        <li>Credential exposure analysis (hashed), if policy enabled</li>
        <li>Impact assessment and recommendations</li>
    </ul>

    <h3>Reconnaissance Tools Used (dynamic)</h3>
    <p>
        {% if active_web_scan.tools_run %}
            Per active scan artifacts: {% for name in active_web_scan.tools_run %}<code>{{ name | e }}</code>{% if not loop.last %}, {% endif %}{% endfor %}.
        {% elif tool_runs %}
            Per tool_runs log: {% for tr in tool_runs %}<code>{{ tr.tool_name | e }}</code>{% if not loop.last %}, {% endif %}{% endfor %}.
        {% else %}
            Tool execution metadata was not included in this export.
        {% endif %}
    </p>

    {% include "partials/valhalla/wstg_coverage_table.html.j2" %}
    {% if vcm and vcm.wstg_execution_degraded %}
    <p class="report-warning"><strong>Methodology limitation:</strong> WSTG-aligned automated coverage is below 70% or is otherwise incomplete. This engagement is labeled <em>{{ vcm.valhalla_engagement_title | e }}</em> and is <strong>not</strong> equivalent to a full manual OWASP WSTG review.</p>
    {% endif %}
    {% if vcm and vcm.wstg_coverage_zero_executed %}
    <p class="report-warning">WSTG coverage is 0% against the mapped 96 test cases in this run; unexecuted areas must be read as <strong>not assessed</strong>.</p>
    {% endif %}
    {% include "partials/valhalla/nist_limitations.html.j2" %}
</section>
