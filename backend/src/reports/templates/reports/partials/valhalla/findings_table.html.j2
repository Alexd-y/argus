{# Valhalla — detailed findings table: confidence, evidence, applicability; advisory separate (T4/T5). #}
{% set labels = owasp_top10_labels if owasp_top10_labels is defined else {} %}
{% set col_count = 11 %}
<section class="findings valhalla-findings" id="findings">
    <h2>Detailed Vulnerability Descriptions (Findings)</h2>
    <table class="findings-main-table">
        <thead>
            <tr>
                <th>Severity</th>
                <th>Confidence</th>
                <th>Evidence</th>
                <th>Applicability</th>
                <th>Vuln-ID</th>
                <th>Title</th>
                <th>Description</th>
                <th>CWE</th>
                <th>OWASP</th>
                <th>CVE</th>
                <th>CVSS</th>
            </tr>
        </thead>
        <tbody>
            {% set primary = namespace(any=false) %}
            {% for row in findings %}
                    {% if not (row.is_advisory | default(false)) %}
                    {% set primary.any = true %}
                <tr>
                    <td><span class="sev-{{ (row.severity or "info") | lower | e }}">{{ (row.severity or "") | e }}</span></td>
                    <td>{{ (row.confidence or "likely") | e }}</td>
                    <td class="desc">{{ (row.evidence_summary or "—") | e }}</td>
                    <td class="desc">{{ (row.applicability_notes or "—") | e }}</td>
                    <td><code>{{ (row.id or "—") | e }}</code></td>
                    <td>{{ (row.title or "") | e }}</td>
                    <td class="desc">{{ (row.description or "") | e }}</td>
                    <td>{{ (row.cwe or "—") | e }}</td>
                    <td class="owasp-finding-cell">
                        {% if row.owasp_category %}
                            <span class="owasp-finding-id"><code>{{ row.owasp_category | e }}</code></span>
                            {% if row.owasp_title %}
                            <span class="owasp-finding-sep"> — </span>
                            <span class="owasp-finding-label">{{ row.owasp_title | e }}</span>
                            {% elif labels.get(row.owasp_category) %}
                            <span class="owasp-finding-sep"> — </span>
                            <span class="owasp-finding-label">{{ labels.get(row.owasp_category) | e }}</span>
                            {% endif %}
                        {% else %}
                            Not found
                        {% endif %}
                    </td>
                    <td>{% if row.cve %}{{ row.cve | e }}{% else %}Not found{% endif %}</td>
                    <td>{% if row.cvss is not none %}{{ row.cvss | e }}{% else %}—{% endif %}</td>
                </tr>
                {% if row.proof_of_concept or (row.http_evidence is defined and row.http_evidence) %}
                    {% set poc = row.proof_of_concept or {} %}
                    {% set has_xss_detail = row.xss_poc_detail is defined and row.xss_poc_detail %}
                    {% set has_http_evidence = row.http_evidence is defined and row.http_evidence %}
                    {% set has_detail = poc.curl_command or poc.javascript_code or poc.request or poc.response or poc.payload or poc.response_snippet or row.poc_screenshot_url or has_xss_detail or has_http_evidence %}
                    {% set param_label = row.parameter or row.param or poc.parameter %}
                    <tr class="poc-row">
                        <td colspan="{{ col_count }}">
                            {% if has_detail %}
                            <section class="finding-poc">
                                <h3 class="finding-poc-title">Evidence (PoC)</h3>
                                {% include "partials/valhalla/finding_xss_poc_detail.html.j2" %}
                                {% include "partials/valhalla/finding_evidence_block.html.j2" %}
                                {% if row.poc_screenshot_url and not (row.http_evidence is defined and row.http_evidence) %}
                                    <p><strong>Screenshot</strong></p>
                                    <p><a href="{{ row.poc_screenshot_url | e }}" target="_blank" rel="noopener noreferrer">Open screenshot</a></p>
                                    {% if embed_poc_screenshot_inline %}
                                    <p class="finding-poc-screenshot-thumb"><img src="{{ row.poc_screenshot_url | e }}" alt="PoC" loading="lazy" style="max-width:100%;max-height:240px;height:auto;" width="320" /></p>
                                    {% endif %}
                                {% endif %}
                                {% if param_label %}
                                    <p><strong>Parameter</strong></p>
                                    <pre class="finding-poc-block"><code>{{ param_label | e }}</code></pre>
                                {% endif %}
                                {% if poc.payload %}
                                    <p><strong>Payload</strong></p>
                                    <pre class="finding-poc-block"><code>{{ poc.payload | e }}</code></pre>
                                {% endif %}
                                {% if poc.javascript_code %}
                                    <p><strong>JavaScript</strong></p>
                                    <pre class="finding-poc-block"><code>{{ poc.javascript_code | e }}</code></pre>
                                {% endif %}
                                {% if poc.curl_command and not (row.http_evidence is defined and row.http_evidence) %}
                                    <p><strong>cURL</strong></p>
                                    <pre class="finding-poc-block"><code>{{ poc.curl_command | e }}</code></pre>
                                {% endif %}
                                {% if poc.request %}
                                    <p><strong>Request</strong></p>
                                    <pre class="finding-poc-block"><code>{{ poc.request | e }}</code></pre>
                                {% endif %}
                                {% if poc.response_snippet %}
                                    <p><strong>Response Snippet</strong></p>
                                    <pre class="finding-poc-block"><code>{{ poc.response_snippet | e }}</code></pre>
                                {% endif %}
                                {% if poc.response %}
                                    <p><strong>Response (excerpt)</strong></p>
                                    <pre class="finding-poc-block"><code>{{ poc.response | e }}</code></pre>
                                {% endif %}
                            </section>
                            {% else %}
                            <p class="finding-poc-empty">No data</p>
                            {% endif %}
                        </td>
                    </tr>
                {% endif %}
                {% if row.reproducible_steps %}
                    <tr class="poc-row finding-repro-row">
                        <td colspan="{{ col_count }}">
                            <p><strong>Reproduction Steps</strong></p>
                            <pre class="finding-poc-block"><code>{{ row.reproducible_steps | e }}</code></pre>
                        </td>
                    </tr>
                {% endif %}
                {% endif %}
            {% endfor %}
            {% if not primary.any %}
                <tr>
                    <td colspan="{{ col_count }}" class="empty">No data</td>
                </tr>
            {% endif %}
        </tbody>
    </table>

    <h3 class="valhalla-advisory-findings-heading">Advisory / Contextual Findings</h3>
    <table class="findings-main-table valhalla-advisory-findings-table">
        <thead>
            <tr>
                <th>Severity</th>
                <th>Confidence</th>
                <th>Evidence</th>
                <th>Applicability</th>
                <th>Vuln-ID</th>
                <th>Title</th>
                <th>Description</th>
                <th>CWE</th>
                <th>OWASP</th>
                <th>CVE</th>
                <th>CVSS</th>
            </tr>
        </thead>
        <tbody>
            {% set adv_ns = namespace(any=false) %}
            {% for row in findings %}
                {% if row.is_advisory | default(false) %}
                    {% set adv_ns.any = true %}
                <tr>
                    <td><span class="sev-{{ (row.severity or "info") | lower | e }}">{{ (row.severity or "") | e }}</span></td>
                    <td>{{ (row.confidence or "advisory") | e }}</td>
                    <td class="desc">{{ (row.evidence_summary or "—") | e }}</td>
                    <td class="desc">{{ (row.applicability_notes or "—") | e }}</td>
                    <td><code>{{ (row.id or "—") | e }}</code></td>
                    <td>{{ (row.title or "") | e }}</td>
                    <td class="desc">{{ (row.description or "") | e }}</td>
                    <td>{{ (row.cwe or "—") | e }}</td>
                    <td class="owasp-finding-cell">
                        {% if row.owasp_category %}
                            <span class="owasp-finding-id"><code>{{ row.owasp_category | e }}</code></span>
                            {% if row.owasp_title %}
                            <span class="owasp-finding-sep"> — </span>
                            <span class="owasp-finding-label">{{ row.owasp_title | e }}</span>
                            {% elif labels.get(row.owasp_category) %}
                            <span class="owasp-finding-sep"> — </span>
                            <span class="owasp-finding-label">{{ labels.get(row.owasp_category) | e }}</span>
                            {% endif %}
                        {% else %}
                            Not found
                        {% endif %}
                    </td>
                    <td>{% if row.cve %}{{ row.cve | e }}{% else %}Not found{% endif %}</td>
                    <td>{% if row.cvss is not none %}{{ row.cvss | e }}{% else %}—{% endif %}</td>
                </tr>
                {% if row.proof_of_concept or (row.http_evidence is defined and row.http_evidence) %}
                    {% set poc = row.proof_of_concept or {} %}
                    {% set has_xss_detail = row.xss_poc_detail is defined and row.xss_poc_detail %}
                    {% set has_http_evidence = row.http_evidence is defined and row.http_evidence %}
                    {% set has_detail = poc.curl_command or poc.javascript_code or poc.request or poc.response or poc.payload or poc.response_snippet or row.poc_screenshot_url or has_xss_detail or has_http_evidence %}
                    {% set param_label = row.parameter or row.param or poc.parameter %}
                    <tr class="poc-row">
                        <td colspan="{{ col_count }}">
                            {% if has_detail %}
                            <section class="finding-poc">
                                <h3 class="finding-poc-title">Evidence (PoC)</h3>
                                {% include "partials/valhalla/finding_xss_poc_detail.html.j2" %}
                                {% include "partials/valhalla/finding_evidence_block.html.j2" %}
                                {% if row.poc_screenshot_url and not (row.http_evidence is defined and row.http_evidence) %}
                                    <p><a href="{{ row.poc_screenshot_url | e }}" target="_blank" rel="noopener noreferrer">Open screenshot</a></p>
                                {% endif %}
                                {% if param_label %}
                                    <pre class="finding-poc-block"><code>{{ param_label | e }}</code></pre>
                                {% endif %}
                                {% if poc.curl_command and not (row.http_evidence is defined and row.http_evidence) %}
                                    <pre class="finding-poc-block"><code>{{ poc.curl_command | e }}</code></pre>
                                {% endif %}
                            </section>
                            {% else %}
                            <p class="finding-poc-empty">No data</p>
                            {% endif %}
                        </td>
                    </tr>
                {% endif %}
                {% if row.reproducible_steps %}
                    <tr class="poc-row finding-repro-row">
                        <td colspan="{{ col_count }}">
                            <p><strong>Reproduction Steps</strong></p>
                            <pre class="finding-poc-block"><code>{{ row.reproducible_steps | e }}</code></pre>
                        </td>
                    </tr>
                {% endif %}
                {% endif %}
            {% endfor %}
            {% if not adv_ns.any %}
                <tr>
                    <td colspan="{{ col_count }}" class="empty">No advisory findings</td>
                </tr>
            {% endif %}
        </tbody>
    </table>
</section>
