{# VH-001 / VH-004 — customer Valhalla: Evidence Inventory (no appendices A-G, no MinIO URLs). #}
{% set vc = valhalla_context if valhalla_context is defined else none %}
<section class="valhalla-evidence-inventory panel" id="evidence-inventory">
    <h2>Evidence Inventory</h2>
    <p class="meta">This table lists evidence references used for findings and key technical sections. Storage paths, API keys, and raw JSON dumps are not included in the customer deliverable.</p>
    {% if vc and vc.evidence_inventory %}
        <table class="valhalla-evidence-inventory-table">
            <thead>
                <tr>
                    <th>Evidence ID</th>
                    <th>Finding / section</th>
                    <th>Source tool</th>
                    <th>Evidence type</th>
                    <th>Summary</th>
                    <th>Timestamp</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                {% for row in vc.evidence_inventory %}
                <tr>
                    <td><code>{{ row.evidence_id | e }}</code></td>
                    <td>{{ row.finding_or_section | e }}</td>
                    <td>{{ row.source_tool | e }}</td>
                    <td>{{ row.evidence_type | e }}</td>
                    <td class="desc">{{ row.summary | e }}</td>
                    <td class="meta">{{ row.timestamp | e }}</td>
                    <td>{{ row.status | e }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="empty">No evidence inventory rows were generated for this export.</p>
    {% endif %}
</section>
