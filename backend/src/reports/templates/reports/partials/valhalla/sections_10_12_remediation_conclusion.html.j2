<section class="valhalla-remediation panel" id="remediation-priority">
    <h2>Recommendations and Prioritization</h2>
    <h3>Vulnerability Remediation Stages</h3>
    <div class="ai-slot-body">
        {% set st = ai_sections.get("remediation_stages") if ai_sections is defined else "" %}
        {% if st and st.strip() %}
            {{ st | md | safe }}
        {% else %}
            <p>Use stack-neutral controls until the technology stack is verified: application middleware, reverse proxy or WAF rules, identity provider settings, monitoring, and repeatable validation evidence.</p>
        {% endif %}
    </div>
    <h3>Priority Roadmap</h3>
    <div class="ai-slot-body">
        {% set road = ai_sections.get("prioritization_roadmap") if ai_sections is defined else "" %}
        {% if road and road.strip() %}
            {{ road | md | safe }}
        {% else %}
            <p>Prioritize remediation by validated severity, evidence quality, and exposed attack surface. Inconclusive areas require follow-up testing before risk acceptance.</p>
        {% endif %}
    </div>
    <h3>Responsible Parties and Timelines</h3>
    <table>
        <thead>
            <tr>
                <th>Vulnerability</th>
                <th>Responsible Department</th>
                <th>Recommended Timeline</th>
            </tr>
        </thead>
        <tbody>
            {% if findings %}
                {% for row in findings if row.severity in ["critical", "high"] %}
                <tr>
                    <td><code>{{ row.id | e }}</code> — {{ row.title | e }} ({{ row.severity | e }})</td>
                    <td>To be determined based on organizational priorities</td>
                    <td>{% if row.severity == "critical" %}Immediate (0–48 hours){% else %}Short-term (1–2 weeks){% endif %}</td>
                </tr>
                {% endfor %}
                {% for row in findings if row.severity in ["medium", "low"] %}
                <tr>
                    <td><code>{{ row.id | e }}</code> — {{ row.title | e }} ({{ row.severity | e }})</td>
                    <td>To be determined based on organizational priorities</td>
                    <td>{% if row.severity == "medium" %}Medium-term (1–3 months){% else %}Planned maintenance cycle{% endif %}</td>
                </tr>
                {% endfor %}
            {% else %}
                <tr>
                    <td colspan="3" class="empty">No vulnerability data available. Timelines to be determined based on organizational priorities.</td>
                </tr>
            {% endif %}
        </tbody>
    </table>
</section>

<section class="valhalla-zero-day panel" id="zero-day-potential">
    <h2>Novel Vulnerability Indication</h2>
    <div class="ai-slot-body">
        {% set zd = ai_sections.get("zero_day_potential") if ai_sections is defined else "" %}
        {% if zd and zd.strip() %}
            {{ zd | md | safe }}
        {% else %}
            <p>Novel vulnerability indication: Not indicated. No novel vulnerability class was demonstrated in the collected evidence.</p>
        {% endif %}
    </div>
</section>

<section class="valhalla-conclusion panel" id="conclusion">
    <h2>Conclusion</h2>
    <h3>Overall Assessment</h3>
    <div class="ai-slot-body">
        {% set ca = ai_sections.get("conclusion_assessment") if ai_sections is defined else "" %}
        {% if ca and ca.strip() %}
            {{ ca | md | safe }}
        {% else %}
            <p>This report is limited to the evidence-backed findings and documented coverage limitations. Missing or failed assessment areas must be treated as inconclusive, not as clean security results.</p>
        {% endif %}
    </div>
    <h3>Hardening Recommendations</h3>
    <p class="meta"><strong>HTTP security headers (stack-neutral):</strong> prefer a strict <strong>Content-Security-Policy</strong>, <strong>X-Content-Type-Options: nosniff</strong>, <strong>Referrer-Policy</strong>, a deliberate <strong>Permissions-Policy</strong>, framing control via <strong>CSP <code>frame-ancestors</code></strong> (or <code>X-Frame-Options</code> as a transitional measure), <strong>Strict-Transport-Security</strong> for HTTPS sites, and where appropriate <strong>Cross-Origin-Opener-Policy</strong> / <strong>Cross-Origin-Resource-Policy</strong>. Avoid legacy browser XSS filter headers (deprecated). Verify with <code>curl -sS -D- -o /dev/null &lt;url&gt;</code> (or equivalent) and review redirects.</p>
    <div class="ai-slot-body">
        {% set hd = ai_sections.get("hardening_recommendations") if ai_sections is defined else "" %}
        {% if hd and hd.strip() %}
            {{ hd | md | safe }}
        {% else %}
            <p>Apply stack-neutral hardening based on verified findings and parsed technical evidence. Avoid framework-specific examples unless the stack is confirmed.</p>
        {% endif %}
    </div>
    <h3>Remediation Steps and Production Readiness</h3>
    <div class="ai-slot-body">
        {% set rs = ai_sections.get("remediation_step") if ai_sections is defined else "" %}
        {% if rs and rs.strip() %}
            {{ rs | md | safe }}
        {% else %}
            <p>Each remediation item should be verified with repeatable requests, timestamps, and raw request/response evidence where applicable.</p>
        {% endif %}
    </div>
    <h3>Additional Vulnerability Descriptions</h3>
    <div class="ai-slot-body">
        {% set vd = ai_sections.get("vulnerability_description") if ai_sections is defined else "" %}
        {% if vd and vd.strip() %}
            {{ vd | md | safe }}
        {% else %}
            <p>No additional vulnerability narrative is available beyond the evidence-backed findings table and technical sections.</p>
        {% endif %}
    </div>
</section>
