{# T6 — structured {status, reason} from valhalla_context.mandatory_sections #}
{% macro section_envelope(vc, section_key) -%}
{% if vc.mandatory_sections is defined and section_key in vc.mandatory_sections %}
{% set env = vc.mandatory_sections[section_key] %}
{% if env.status != 'completed' %}
<p class="meta valhalla-mandatory-status"><strong>Data status ({{ section_key }}):</strong> {{ env.status | e }}{% if env.reason %} — {{ env.reason | e }}{% endif %}</p>
{% endif %}
{% endif %}
{%- endmacro %}
