{# Обзор результатов и матрица рисков #}
{% set vc = valhalla_context %}
{% from "partials/valhalla/section_status_macro.html.j2" import section_envelope %}
{% set robots = vc.robots_txt_analysis %}
{% set sm = vc.sitemap_analysis %}
{% set ssl = vc.ssl_tls_analysis %}
{% set hdrs = vc.security_headers_analysis %}
{% set rsa = vc.robots_sitemap_analysis if vc.robots_sitemap_analysis is defined else none %}

<section class="valhalla-results panel" id="results-overview">
    <h2>Обзор результатов и матрица рисков</h2>

    {% include "partials/valhalla/section_data_coverage.html.j2" %}

    <h3>Анализ robots.txt и sitemap.xml</h3>
    {{ section_envelope(vc, "robots_sitemap_analysis") }}
    {% if vc.robots_sitemap_fallback_message %}
        <p class="meta">{{ vc.robots_sitemap_fallback_message | e }}</p>
    {% endif %}
    {% if vc.robots_sitemap_merged and vc.robots_sitemap_merged.notes_ru %}
        <p class="meta"><small>{{ vc.robots_sitemap_merged.notes_ru | e }}</small></p>
    {% endif %}
    <p><strong>robots.txt:</strong> {% if robots.found %}Найдено{% else %}Не найдено{% endif %}</p>
    {% if robots.disallowed_paths_sample %}
        <p>Содержит пути (выборка): {{ robots.disallowed_paths_sample | join(", ") | e }}</p>
    {% else %}
        <p class="empty">Нет данных</p>
    {% endif %}
    {% if robots.sitemap_hints %}
        <p>Упоминания sitemap: {{ robots.sitemap_hints | join(", ") | e }}</p>
    {% endif %}
    {% if robots.sensitive_path_hints %}
        <p><strong>Чувствительные шаблоны путей (эвристика):</strong> {{ robots.sensitive_path_hints | join(", ") | e }}</p>
    {% endif %}
    {% if rsa and rsa.merged %}
        <p class="meta"><small>Сводка (robots_sitemap_analysis.merged): robots={{ rsa.merged.robots_found | default(false) }}, sitemap={{ rsa.merged.sitemap_found | default(false) }}, security.txt={{ rsa.merged.security_txt_reachable | default(false) }}, URL в sitemap: {{ rsa.merged.sitemap_url_count | default(0) }}</small></p>
    {% endif %}

    <p><strong>sitemap.xml:</strong> {% if sm.found %}Найдено{% else %}Не найдено{% endif %}{% if sm.index_found %} (в т.ч. индекс){% endif %}</p>
    <p><strong>Количество URL:</strong> {{ sm.url_count if sm.url_count is not none else 0 }}</p>
    {% if sm.sample_urls %}
        <p><strong>Примеры:</strong> {{ sm.sample_urls | join(", ") | e }}</p>
    {% else %}
        <p class="empty">Нет данных</p>
    {% endif %}

    <h3>Сводная строка по примеру уязвимости (первая находка, при наличии)</h3>
    {% if findings|length > 0 %}
        {% set f0 = findings[0] %}
        <table>
            <tbody>
                <tr><th scope="row">Идентификатор / название</th><td>{{ f0.id | e }} — {{ f0.title | e }}</td></tr>
                <tr><th scope="row">Описание</th><td class="desc">{{ f0.description or "Нет данных" }}</td></tr>
                <tr><th scope="row">Критичность</th><td>{{ f0.severity | e }}</td></tr>
                <tr><th scope="row">CWE</th><td>{{ f0.cwe or "Не найдено" }}</td></tr>
                <tr><th scope="row">OWASP</th><td>{% if f0.owasp_category %}{{ f0.owasp_category | e }}{% else %}Не найдено{% endif %}</td></tr>
                <tr><th scope="row">CVSS</th><td>{% if f0.cvss is not none %}{{ f0.cvss }}{% else %}—{% endif %}</td></tr>
                <tr><th scope="row">CVE</th><td>{{ f0.cve or "Не найдено" }}</td></tr>
            </tbody>
        </table>
    {% else %}
        <p class="empty">Нет данных</p>
    {% endif %}

    <h3>Технологический стек и компоненты</h3>
    {{ section_envelope(vc, "tech_stack_structured") }}
    {% if vc.tech_stack_fallback_message %}
        <p class="meta">{{ vc.tech_stack_fallback_message | e }}</p>
    {% endif %}
    {% set ts = vc.tech_stack_structured %}
    {% if ts and (ts.web_server or ts.os or ts.cms or ts.frameworks or ts.js_libraries or ts.ports_summary or ts.services_summary) %}
        <table class="valhalla-tech-structured">
            <thead>
                <tr>
                    <th>Веб-сервер</th>
                    <th>ОС</th>
                    <th>CMS</th>
                    <th>Фреймворки</th>
                    <th>JS-библиотеки</th>
                    <th>Порты</th>
                    <th>Сервисы</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>{{ ts.web_server | e }}</td>
                    <td>{{ ts.os | e }}</td>
                    <td>{{ ts.cms | e }}</td>
                    <td>{% if ts.frameworks %}{{ ts.frameworks | join(", ") | e }}{% else %}—{% endif %}</td>
                    <td>{% if ts.js_libraries %}{{ ts.js_libraries | join(", ") | e }}{% else %}—{% endif %}</td>
                    <td>{{ ts.ports_summary | e }}</td>
                    <td class="desc">{{ ts.services_summary | e }}</td>
                </tr>
            </tbody>
        </table>
    {% endif %}
    {% if ts and ts.entries %}
        <h4>WhatWeb / детальные записи</h4>
        <table>
            <thead>
                <tr><th>Технология</th><th>Версия</th><th>Уверенность</th></tr>
            </thead>
            <tbody>
                {% for e in ts.entries %}
                <tr>
                    <td>{{ e.technology | e }}</td>
                    <td>{{ e.version or "—" }}</td>
                    <td>{% if e.confidence is not none %}{{ e.confidence }}{% else %}—{% endif %}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
    {% if vc.tech_stack_table %}
        <table>
            <thead>
                <tr>
                    <th>Категория</th>
                    <th>Компонент</th>
                    <th>Детали</th>
                    <th>Источник</th>
                </tr>
            </thead>
            <tbody>
                {% for row in vc.tech_stack_table %}
                <tr>
                    <td>{{ row.category | e }}</td>
                    <td>{{ row.name | e }}</td>
                    <td>{{ row.detail | e }}</td>
                    <td>{{ row.source | e }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="empty">Не найдено</p>
    {% endif %}

    <h3>Устаревшие компоненты</h3>
    {{ section_envelope(vc, "outdated_components") }}
    {% if vc.outdated_components_fallback_message %}
        <p class="meta">{{ vc.outdated_components_fallback_message | e }}</p>
    {% endif %}
    {% if vc.outdated_components %}
        <table>
            <thead>
                <tr>
                    <th>Компонент</th>
                    <th>Версия (установленная)</th>
                    <th>Последняя стабильная</th>
                    <th>Статус / источник</th>
                    <th>CVE</th>
                    <th>Публичный эксплойт (эвристика)</th>
                    <th>Рекомендация</th>
                </tr>
            </thead>
            <tbody>
                {% for row in vc.outdated_components %}
                <tr>
                    <td>{{ row.component | e }}</td>
                    <td>{{ row.installed_version or "—" }}</td>
                    <td>{{ row.latest_stable or "—" }}</td>
                    <td>{{ row.support_status or "—" }}</td>
                    <td>{% if row.cves %}{{ row.cves | join(", ") | e }}{% else %}—{% endif %}</td>
                    <td>{% if row.exploit_available %}Да{% else %}Нет / н/д{% endif %}</td>
                    <td class="desc">{{ row.recommendation | e }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="empty">Не найдено</p>
    {% endif %}

    <h3>Обнаруженные email-адреса (маскированные)</h3>
    {{ section_envelope(vc, "leaked_emails") }}
    {% if vc.leaked_emails_fallback_message and not vc.leaked_emails %}
        <p class="meta">{{ vc.leaked_emails_fallback_message | e }}</p>
    {% endif %}
    {% if vc.leaked_emails %}
        <ul>
            {% for e in vc.leaked_emails %}
            <li>{{ e | e }}</li>
            {% endfor %}
        </ul>
    {% else %}
        <p class="empty">Не найдено</p>
    {% endif %}

    <h3>Результаты проверки SSL/TLS</h3>
    {{ section_envelope(vc, "ssl_tls_analysis") }}
    {% if vc.ssl_tls_fallback_message %}
        <p class="meta">{{ vc.ssl_tls_fallback_message | e }}</p>
    {% endif %}
    <table>
        <tbody>
            <tr><th scope="row">Издатель сертификата</th><td>{{ ssl.issuer or "Не найдено" }}</td></tr>
            <tr><th scope="row">Срок действия</th><td>{{ ssl.validity or "Не найдено" }}</td></tr>
            <tr><th scope="row">Поддерживаемые протоколы</th><td>{% if ssl.protocols %}{{ ssl.protocols | join(", ") | e }}{% else %}Нет данных{% endif %}</td></tr>
            <tr><th scope="row">Слабые / устаревшие протоколы</th><td>{% if ssl.weak_protocols %}{{ ssl.weak_protocols | join(", ") | e }}{% else %}Не найдено / нет данных{% endif %}</td></tr>
            <tr><th scope="row">Слабые шифры</th><td>{% if ssl.weak_ciphers %}{{ ssl.weak_ciphers | join(", ") | e }}{% else %}Не найдено / нет данных{% endif %}</td></tr>
            <tr><th scope="row">HSTS</th><td>{{ ssl.hsts or "Нет данных" }}</td></tr>
        </tbody>
    </table>

    <h3>Анализ HTTP-заголовков безопасности</h3>
    {{ section_envelope(vc, "security_headers_analysis") }}
    {% if vc.security_headers_fallback_message %}
        <p class="meta">{{ vc.security_headers_fallback_message | e }}</p>
    {% endif %}
    {% if hdrs.summary %}
        <p>{{ hdrs.summary | e }}</p>
    {% endif %}
    {% if hdrs.rows %}
        <table>
            <thead>
                <tr>
                    <th>Хост (если есть)</th>
                    <th>Заголовок</th>
                    <th>Значение (выборка)</th>
                    <th>Статус</th>
                </tr>
            </thead>
            <tbody>
                {% for r in hdrs.rows %}
                <tr>
                    <td>{{ r.host | default("—") | e }}</td>
                    <td>{{ r.header | e }}</td>
                    <td>{{ r.value_sample | default("—") | e }}</td>
                    <td>{% if r.present %}✅{% else %}❌{% endif %}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="empty">Нет данных</p>
    {% endif %}

    <h3>Анализ компонентов и зависимостей</h3>
    {% if vc.dependency_analysis %}
        <table>
            <thead>
                <tr>
                    <th>Компонент</th>
                    <th>Версия</th>
                    <th>Критичность</th>
                    <th>Источник</th>
                    <th>Детали / рекомендация</th>
                </tr>
            </thead>
            <tbody>
                {% for d in vc.dependency_analysis %}
                <tr>
                    <td>{{ d.package | e }}</td>
                    <td>{{ d.version or "—" }}</td>
                    <td>{{ d.severity or "—" }}</td>
                    <td>{{ d.source | e }}</td>
                    <td>{{ d.detail or "—" }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="empty">Не найдено</p>
    {% endif %}

    <h3>Матрица рисков (Impact × Likelihood)</h3>
    <p class="meta"><small>Оси: Low / Medium / High (0–3 → группы); ячейки — число находок и их идентификаторы.</small></p>
    {% set rm = vc.risk_matrix %}
    {% set ax = {"low": "Низкий", "medium": "Средний", "high": "Высокий"} %}
    {% if rm.cells %}
        <table>
            <thead>
                <tr>
                    <th>Влияние</th>
                    <th>Вероятность</th>
                    <th>Количество</th>
                    <th>Finding IDs</th>
                </tr>
            </thead>
            <tbody>
                {% for c in rm.cells %}
                <tr>
                    <td>{{ ax.get(c.impact, c.impact) | e }} <span class="meta">({{ c.impact | e }})</span></td>
                    <td>{{ ax.get(c.likelihood, c.likelihood) | e }} <span class="meta">({{ c.likelihood | e }})</span></td>
                    <td>{{ c.count }}</td>
                    <td>{{ c.finding_ids | join(", ") | e }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="empty">Нет данных</p>
    {% endif %}

    <h3>Критически важные уязвимости (немедленное исправление)</h3>
    <p class="meta"><small>CVSS ≥ 7.0 и подтверждение / признаки эксплуатации (PoC, CVE+exploit, verified).</small></p>
    {% if vc.critical_vulns %}
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Название</th>
                    <th>Кратко</th>
                    <th>CVSS</th>
                    <th>Эксплойт</th>
                </tr>
            </thead>
            <tbody>
                {% for v in vc.critical_vulns %}
                <tr>
                    <td><code>{{ v.vuln_id | e }}</code></td>
                    <td>{{ v.title | e }}{% if v.severity %} <span class="meta">({{ v.severity | e }})</span>{% endif %}</td>
                    <td class="desc">{{ v.description | e }}</td>
                    <td>{% if v.cvss is not none %}{{ v.cvss }}{% else %}—{% endif %}</td>
                    <td>{% if v.exploit_available %}да{% else %}нет{% endif %}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="empty">Не найдено</p>
    {% endif %}
</section>
