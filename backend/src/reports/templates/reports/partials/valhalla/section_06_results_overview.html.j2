{# Results overview and risk matrix #}
{% set vc = valhalla_context %}
{% from "partials/valhalla/section_status_macro.html.j2" import section_envelope %}
{% set robots = vc.robots_txt_analysis %}
{% set sm = vc.sitemap_analysis %}
{% set ssl = vc.ssl_tls_analysis %}
{% set hdrs = vc.security_headers_analysis %}
{% set rsa = vc.robots_sitemap_analysis if vc.robots_sitemap_analysis is defined else none %}

<section class="valhalla-results panel" id="results-overview">
    <h2>Results Overview and Risk Matrix</h2>

    {% include "partials/valhalla/section_data_coverage.html.j2" %}
    {% include "partials/valhalla/active_injection_coverage.html.j2" %}

    <h3>robots.txt and sitemap.xml Analysis</h3>
    {{ section_envelope(vc, "robots_sitemap_analysis") }}
    {% if vc.robots_sitemap_fallback_message %}
        <p class="meta">{{ vc.robots_sitemap_fallback_message | e }}</p>
    {% endif %}
    {% if vc.robots_sitemap_merged and (vc.robots_sitemap_merged.notes or vc.robots_sitemap_merged.notes_ru) %}
        <p class="meta"><small>{{ (vc.robots_sitemap_merged.notes or vc.robots_sitemap_merged.notes_ru) | e }}</small></p>
    {% endif %}
    <p><strong>robots.txt:</strong> {% if robots.found %}Found{% else %}Not retrieved in parsed context{% endif %}</p>
    {% if robots.disallowed_paths_sample %}
        <p>Contains paths (sample): {{ robots.disallowed_paths_sample | join(", ") | e }}</p>
    {% else %}
        <p class="empty">No robots.txt allow/disallow entries were parsed.</p>
    {% endif %}
    {% if robots.sitemap_hints %}
        <p>Sitemap references: {{ robots.sitemap_hints | join(", ") | e }}</p>
    {% endif %}
    {% if robots.sensitive_path_hints %}
        <p><strong>Sensitive path patterns (heuristic):</strong> {{ robots.sensitive_path_hints | join(", ") | e }}</p>
    {% endif %}
    {% if rsa and rsa.merged %}
        <p class="meta"><small>Summary (robots_sitemap_analysis.merged): robots={{ rsa.merged.robots_found | default(false) }}, sitemap={{ rsa.merged.sitemap_found | default(false) }}, security.txt={{ rsa.merged.security_txt_reachable | default(false) }}, URLs in sitemap: {{ rsa.merged.sitemap_url_count | default(0) }}</small></p>
    {% endif %}

    <p><strong>sitemap.xml:</strong> {% if sm.found %}Found{% else %}Not retrieved in parsed context{% endif %}{% if sm.index_found %} (including index){% endif %}</p>
    <p><strong>URL count:</strong> {{ sm.url_count if sm.url_count is not none else 0 }}</p>
    {% if sm.sample_urls %}
        <p><strong>Examples:</strong> {{ sm.sample_urls | join(", ") | e }}</p>
    {% else %}
        <p class="empty">No sitemap URL examples were parsed.</p>
    {% endif %}

    <h3>Sample Vulnerability Summary (first finding, if available)</h3>
    {% if findings|length > 0 %}
        {% set f0 = findings[0] %}
        <table>
            <tbody>
                <tr><th scope="row">Identifier / Title</th><td>{{ f0.id | e }} — {{ f0.title | e }}</td></tr>
                <tr><th scope="row">Description</th><td class="desc">{{ f0.description or "Description was not provided." }}</td></tr>
                <tr><th scope="row">Severity</th><td>{{ f0.severity | e }}</td></tr>
                <tr><th scope="row">CWE</th><td>{{ f0.cwe or "Not mapped" }}</td></tr>
                {% set f0_owasp = f0.owasp_top10_2021 or f0.owasp_display_code or f0.owasp_category %}
                <tr><th scope="row">OWASP</th><td>{% if f0_owasp %}{{ f0_owasp | e }}{% else %}Not mapped{% endif %}</td></tr>
                <tr><th scope="row">CVSS</th><td>{% if f0.cvss is not none %}{{ f0.cvss }}{% else %}—{% endif %}</td></tr>
                <tr><th scope="row">CVE</th><td>{{ f0.cve or "No CVE identifier provided" }}</td></tr>
            </tbody>
        </table>
    {% else %}
        <p class="empty">No reportable findings are listed in this report context.</p>
    {% endif %}

    <h3>Technology Stack and Components</h3>
    {{ section_envelope(vc, "tech_stack_structured") }}
    {% if vc.tech_stack_fallback_message %}
        <p class="meta">{{ vc.tech_stack_fallback_message | e }}</p>
    {% endif %}
    {% set ts = vc.tech_stack_structured %}
    {% if ts and (ts.web_server or ts.os or ts.cms or ts.frameworks or ts.js_libraries or ts.ports_summary or ts.services_summary) %}
        <table class="valhalla-tech-structured">
            <thead>
                <tr>
                    <th>Web Server</th>
                    <th>OS</th>
                    <th>CMS</th>
                    <th>Frameworks</th>
                    <th>JS Libraries</th>
                    <th>Ports</th>
                    <th>Services</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>{{ ts.web_server | e }}</td>
                    <td>{{ ts.os | e }}</td>
                    <td>{{ ts.cms | e }}</td>
                    <td>{% if ts.frameworks %}{{ ts.frameworks | join(", ") | e }}{% else %}—{% endif %}</td>
                    <td>{% if ts.js_libraries %}{{ ts.js_libraries | join(", ") | e }}{% else %}—{% endif %}</td>
                    <td>{{ ts.ports_summary | e }}</td>
                    <td class="desc">{{ ts.services_summary | e }}</td>
                </tr>
            </tbody>
        </table>
    {% endif %}
    {% if ts and ts.entries %}
        <h4>WhatWeb / Detailed Entries</h4>
        <table>
            <thead>
                <tr><th>Technology</th><th>Version</th><th>Confidence</th></tr>
            </thead>
            <tbody>
                {% for e in ts.entries %}
                <tr>
                    <td>{{ e.technology | e }}</td>
                    <td>{{ e.version or "—" }}</td>
                    <td>{% if e.confidence is not none %}{{ e.confidence }}{% else %}—{% endif %}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
    {% if vc.tech_stack_table %}
        <table>
            <thead>
                <tr>
                    <th>Component</th>
                    <th>Detected value</th>
                    <th>Version</th>
                    <th>Source</th>
                    <th>Confidence</th>
                    <th>Security note</th>
                </tr>
            </thead>
            <tbody>
                {% for row in vc.tech_stack_table %}
                <tr>
                    <td>{{ row.category | e }}</td>
                    <td>{{ row.name | e }}</td>
                    <td>{{ row.version or "—" }}</td>
                    <td>{{ row.source | e }}</td>
                    <td>{{ row.confidence or "—" }}</td>
                    <td class="desc">{{ row.security_note or row.detail or "Parsed technology signal; verify before stack-specific remediation." }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="empty">No customer-facing technology rows were parsed for this run.</p>
    {% endif %}

    <h3>Outdated Components</h3>
    {{ section_envelope(vc, "outdated_components") }}
    {% if vc.outdated_components_fallback_message %}
        <p class="meta">{{ vc.outdated_components_fallback_message | e }}</p>
    {% endif %}
    {% if vc.outdated_components %}
        <table>
            <thead>
                <tr>
                    <th>Component</th>
                    <th>Detected version</th>
                    <th>Latest / fixed version</th>
                    <th>CVE / advisory</th>
                    <th>Severity</th>
                    <th>Source</th>
                    <th>Recommendation</th>
                </tr>
            </thead>
            <tbody>
                {% for row in vc.outdated_components %}
                <tr>
                    <td>{{ row.component | e }}</td>
                    <td>{{ row.installed_version or "—" }}</td>
                    <td>{{ row.latest_stable or "—" }}</td>
                    <td>{% if row.cves %}{{ row.cves | join(", ") | e }}{% else %}—{% endif %}</td>
                    <td>{{ row.support_status or "—" }}</td>
                    <td>{{ row.source or "—" }}</td>
                    <td class="desc">{{ row.recommendation | e }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="empty">No component/version rows were parsed for this section.</p>
    {% endif %}

    <h3>Discovered Email Addresses (masked)</h3>
    {{ section_envelope(vc, "leaked_emails") }}
    {% if vc.leaked_emails_fallback_message and not vc.leaked_emails %}
        <p class="meta">{{ vc.leaked_emails_fallback_message | e }}</p>
    {% endif %}
    {% if vc.leaked_email_rows %}
        <table>
            <thead>
                <tr>
                    <th>Email / masked email</th>
                    <th>Source</th>
                    <th>Context</th>
                    <th>Risk</th>
                    <th>Evidence ID</th>
                </tr>
            </thead>
            <tbody>
                {% for row in vc.leaked_email_rows %}
                <tr>
                    <td>{{ row.email | e }}</td>
                    <td>{{ row.source | e }}</td>
                    <td class="desc">{{ row.context | e }}</td>
                    <td class="desc">{{ row.risk | e }}</td>
                    <td><code>{{ row.evidence_id | e }}</code></td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="empty">Email-capable sources were parsed only when indicated by the section status; no email-like values are listed here.</p>
    {% endif %}

    <h3>Credential Exposure Check — HIBP Pwned Passwords (aggregate)</h3>
    {% if hibp_pwned_password_summary is defined and hibp_pwned_password_summary %}
        {% set hp = hibp_pwned_password_summary %}
        <table>
            <tbody>
                <tr><th scope="row">Sample values checked (k-anonymity API)</th><td>{{ hp.checks_run | default(0) | int }}</td></tr>
                <tr><th scope="row">Matches in Pwned Passwords corpus</th><td>{{ hp.pwned_count | default(0) | int }}</td></tr>
            <tr><th scope="row">Password exposure signal</th><td>{{ hp.data_breach_password_exposure | default("—") | e }}</td></tr>
            </tbody>
        </table>
        {% if hp.breach_signal_note %}
            <p class="ai-slot-body">{{ hp.breach_signal_note | e }}</p>
        {% endif %}
        {% if hp.note %}
            <p class="muted"><small>{{ hp.note | e }}</small></p>
        {% endif %}
    {% else %}
        <p class="empty">No aggregated HIBP data was available for this assessment.</p>
    {% endif %}

    <h3>Port Exposure</h3>
    {{ section_envelope(vc, "port_exposure") }}
    {% if vc.port_exposure_table_rows %}
        <table class="valhalla-port-exposure-table">
            <thead>
                <tr>
                    <th>Host</th>
                    <th>Port</th>
                    <th>Protocol</th>
                    <th>State</th>
                    <th>Service</th>
                    <th>Version</th>
                    <th>Source</th>
                    <th>Confidence</th>
                    <th>Exposure note</th>
                </tr>
            </thead>
            <tbody>
                {% for row in vc.port_exposure_table_rows %}
                <tr>
                    <td>{{ row.host | e }}</td>
                    <td>{{ row.port | e }}</td>
                    <td>{{ row.protocol | e }}</td>
                    <td>{{ row.state | e }}</td>
                    <td>{{ row.service or "—" }}</td>
                    <td>{{ row.version or "—" }}</td>
                    <td>{{ row.source | e }}</td>
                    <td>{{ row.confidence | e }}</td>
                    <td class="desc">{{ row.exposure_note | e }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="empty">No customer-facing port rows were parsed for this run.</p>
    {% endif %}

    <h3>SSL/TLS Analysis Results</h3>
    {{ section_envelope(vc, "ssl_tls_analysis") }}
    {% if vc.ssl_tls_fallback_message %}
        <p class="meta">{{ vc.ssl_tls_fallback_message | e }}</p>
    {% endif %}
    {% if vc.ssl_tls_table_rows is defined and vc.ssl_tls_table_rows %}
    <table class="valhalla-ssl-tls-table">
        <thead>
            <tr>
                <th>Domain</th>
                <th>Certificate subject</th>
                <th>Issuer</th>
                <th>Validity (dates)</th>
                <th>Days remaining</th>
                <th>TLS 1.0</th>
                <th>TLS 1.1</th>
                <th>TLS 1.2</th>
                <th>TLS 1.3</th>
                <th>Weak ciphers</th>
                <th>HSTS</th>
                <th>Chain issues</th>
                <th>Evidence ID</th>
            </tr>
        </thead>
        <tbody>
            {% for tr in vc.ssl_tls_table_rows %}
            <tr>
                <td>{{ tr.domain | e }}</td>
                <td class="desc">{{ tr.cert_subject | e }}</td>
                <td class="desc">{{ tr.issuer | e }}</td>
                <td class="desc">{{ tr.dates | e }}</td>
                <td>{{ tr.days_remaining | e }}</td>
                <td>{{ tr.tls_1_0 | e }}</td>
                <td>{{ tr.tls_1_1 | e }}</td>
                <td>{{ tr.tls_1_2 | e }}</td>
                <td>{{ tr.tls_1_3 | e }}</td>
                <td class="desc">{{ tr.weak_ciphers | e }}</td>
                <td class="desc">{{ tr.hsts | e }}</td>
                <td>{{ tr.chain_issues | e }}</td>
                <td><code>{{ tr.evidence_id | e }}</code></td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    <p class="meta"><small>When certificate rows come from multiple hosts, HSTS and TLS protocol cells may reflect the aggregate testssl / recon summary.</small></p>
    {% else %}
    <p class="empty">No customer-facing TLS rows were parsed for this run.</p>
    {% endif %}

    <h3>HTTP Security Headers Analysis</h3>
    {{ section_envelope(vc, "security_headers_analysis") }}
    {% if vc.security_headers_fallback_message %}
        <p class="meta">{{ vc.security_headers_fallback_message | e }}</p>
    {% endif %}
    {% if hdrs.summary %}
        <p>{{ hdrs.summary | e }}</p>
    {% endif %}
    {% if vc.security_headers_table_rows is defined and vc.security_headers_table_rows %}
        <table class="valhalla-sec-headers-table">
            <thead>
                <tr>
                    <th>URL</th>
                    <th>Header</th>
                    <th>Status</th>
                    <th>Observed</th>
                    <th>Risk</th>
                    <th>Recommendation</th>
                    <th>Evidence ID</th>
                </tr>
            </thead>
            <tbody>
                {% for r in vc.security_headers_table_rows %}
                <tr>
                    <td class="desc">{{ r.url | e }}</td>
                    <td>{{ r.header | e }}</td>
                    <td>{{ r.status | e }}</td>
                    <td class="desc">{{ r.observed | e }}</td>
                    <td>{{ r.risk | e }}</td>
                    <td class="desc">{{ r.recommendation | e }}</td>
                    <td><code>{{ r.evidence_id | e }}</code></td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% elif hdrs.rows %}
        <table>
            <thead>
                <tr>
                    <th>Host (if available)</th>
                    <th>Header</th>
                    <th>Value (sample)</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                {% for r in hdrs.rows %}
                <tr>
                    <td>{{ r.host | default("—") | e }}</td>
                    <td>{{ r.header | e }}</td>
                    <td>{{ r.value_sample | default("—") | e }}</td>
                    <td>{% if r.present %}present{% else %}missing{% endif %}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="empty">No customer-facing security header rows were parsed for this run.</p>
    {% endif %}

    <h3>Component and Dependency Analysis</h3>
    {% if vc.dependency_analysis %}
        <table>
            <thead>
                <tr>
                    <th>Component</th>
                    <th>Version</th>
                    <th>Severity</th>
                    <th>Source</th>
                    <th>Details / Recommendation</th>
                </tr>
            </thead>
            <tbody>
                {% for d in vc.dependency_analysis %}
                <tr>
                    <td>{{ d.package | e }}</td>
                    <td>{{ d.version or "—" }}</td>
                    <td>{{ d.severity or "—" }}</td>
                    <td>{{ d.source | e }}</td>
                    <td>{{ d.detail or "—" }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="empty">No dependency inventory rows were parsed for this run.</p>
    {% endif %}

    <h3>Risk Matrix (Impact × Likelihood)</h3>
    <p class="meta"><small>Axes: Low / Medium / High (0–3 → groups); cells — finding count and IDs.</small></p>
    {% set rm = vc.risk_matrix %}
    {% set ax = {"low": "Low", "medium": "Medium", "high": "High"} %}
    {% if rm.cells %}
        <table>
            <thead>
                <tr>
                    <th>Impact</th>
                    <th>Likelihood</th>
                    <th>Count</th>
                    <th>Finding IDs</th>
                </tr>
            </thead>
            <tbody>
                {% for c in rm.cells %}
                <tr>
                    <td>{{ ax.get(c.impact, c.impact) | e }} <span class="meta">({{ c.impact | e }})</span></td>
                    <td>{{ ax.get(c.likelihood, c.likelihood) | e }} <span class="meta">({{ c.likelihood | e }})</span></td>
                    <td>{{ c.count }}</td>
                    <td>{{ c.finding_ids | join(", ") | e }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="empty">No risk matrix rows were produced because there were no reportable findings.</p>
    {% endif %}

    <h3>Critical Vulnerabilities (immediate remediation required)</h3>
    <p class="meta"><small>Only findings with <strong>Critical</strong> severity or <strong>CVSS ≥ 9.0</strong>, <strong>validated</strong> status, <strong>strong</strong> evidence, and <strong>exploit demonstrated</strong> (passive header gaps are excluded). Exploit is shown as “yes” only with demonstrated exploit evidence.</small></p>
    {% if vc.critical_vulns %}
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Summary</th>
                    <th>CVSS</th>
                    <th>Exploit demonstrated</th>
                </tr>
            </thead>
            <tbody>
                {% for v in vc.critical_vulns %}
                <tr>
                    <td><code>{{ v.vuln_id | e }}</code></td>
                    <td>{{ v.title | e }}{% if v.severity %} <span class="meta">({{ v.severity | e }})</span>{% endif %}</td>
                    <td class="desc">{{ v.description | e }}</td>
                    <td>{% if v.cvss is not none %}{{ v.cvss }}{% else %}—{% endif %}</td>
                    <td>{% if v.exploit_demonstrated is defined and v.exploit_demonstrated %}yes{% else %}no{% endif %}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="empty">No validated critical vulnerabilities met the evidence threshold for this section.</p>
    {% endif %}
</section>
