<section class="recon-summary panel" id="recon-summary">
    <h2>Recon summary</h2>
    <p><strong>Target:</strong> {{ recon_summary.target_url or "—" }}</p>
    {% if recon_summary.scan %}
        <p><strong>Scan status:</strong> {{ recon_summary.scan.status or "—" }}
            {% if recon_summary.scan.phase %} / phase {{ recon_summary.scan.phase }}{% endif %}
        </p>
    {% endif %}
    <p><strong>Technologies:</strong>
        {% if recon_summary.technologies %}
            {{ recon_summary.technologies | join(", ") }}
        {% else %}
            <span class="empty">None listed</span>
        {% endif %}
    </p>
    <p><strong>Severity counts:</strong>
        {% if recon_summary.summary_counts %}
            {% for k, v in recon_summary.summary_counts.items() %}
                {{ k }}: {{ v }}{% if not loop.last %}; {% endif %}
            {% endfor %}
        {% else %}
            <span class="empty">No summary blob</span>
        {% endif %}
    </p>
    <p><strong>Phase I/O:</strong> inputs {{ recon_summary.phase_inputs_count }}, outputs {{ recon_summary.phase_outputs_count }}; timeline entries {{ recon_summary.timeline_count }}; findings {{ recon_summary.findings_count }}</p>
    {% if recon_summary.timeline_preview %}
        <h3>Timeline (preview)</h3>
        <ul class="timeline">
            {% for row in recon_summary.timeline_preview %}
                <li><strong>{{ row.phase }}</strong> (#{{ row.order_index }}){% if row.snippet %}: {{ row.snippet }}{% endif %}</li>
            {% endfor %}
        </ul>
    {% endif %}
</section>
