{
  "name": "argus-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 127.0.0.1 -p 5000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "verify:playwright-config": "playwright test --list --project=chromium",
    "test:e2e:vuln-smoke": "playwright test --project=vuln-smoke",
    "test:e2e:a11y": "playwright test --config playwright.a11y.config.ts",
    "test:e2e:functional": "playwright test --config playwright.mock.config.ts",
    "test:e2e:install": "playwright install --with-deps",
    "sdk:generate": "openapi --input ../docs/mcp-server-openapi.yaml --output ./src/sdk/argus-mcp --client fetch --useUnionTypes --useOptions --indent 2",
    "sdk:check": "npm run sdk:generate && git diff --exit-code --stat src/sdk/argus-mcp"
  },
  "dependencies": {
    "@rjsf/core": "^6.5.0",
    "@rjsf/utils": "^6.5.0",
    "@rjsf/validator-ajv8": "^6.5.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-virtual": "^3.13.24",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-json-view-lite": "^2.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^25.0.1",
    "openapi-typescript-codegen": "0.29.0",
    "tailwindcss": "^4",
    "typescript": "5.9.3",
    "vitest": "^3"
  }
}
