# ARGUS Frontend - API base URL
# Relative path: fetch goes to same-origin, Next.js rewrites to backend — no CORS needed
NEXT_PUBLIC_API_URL=/api/v1

# Optional: backend URL for rewrite (default http://localhost:8000 in next.config)
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Server-only (Next.js Server Actions / Node): must match backend ADMIN_API_KEY.
# Never use NEXT_PUBLIC_* for this value and never call the browser to FastAPI admin with the key.
# ADMIN_API_KEY=

# Server-only base URL for admin server actions (defaults to NEXT_PUBLIC_BACKEND_URL, then localhost:8000)
# BACKEND_URL=http://localhost:8000

# ─── MCP integration (ARG-042) ────────────────────────────────────────────────
# Feature flag — when unset or "false", /mcp shows a NotEnabledNotice and the
# rest of the application is unchanged. Set to "true" to opt in.
NEXT_PUBLIC_MCP_ENABLED=false

# Base URL of the MCP server. Defaults to http://127.0.0.1:8000/mcp when unset.
# Override per-environment (staging / prod) — never bake a tenant token here.
NEXT_PUBLIC_MCP_BASE_URL=http://127.0.0.1:8000/mcp

# ─── Admin console (Batch 2) — dev-only role simulation ─────────────────────────
# Not a secret: simulates operator | admin | super-admin for local UI. Production
# must use server-enforced sessions; this only affects the client shell.
# NEXT_PUBLIC_ADMIN_DEV_ROLE=operator

# ─── Admin auth mode (B6-T09 / ISS-T20-003 Phase 1 frontend) ────────────────────
# Selects how the Next.js admin console resolves the operator's identity:
#   - cookie  : legacy shim — reads `argus.admin.role` / `argus.admin.tenant` /
#               `argus.admin.subject` cookies and `NEXT_PUBLIC_ADMIN_DEV_*`.
#               No backend round-trip; use only for local dev / Playwright.
#   - session : new mode — server-side calls backend GET /api/v1/auth/admin/whoami
#               using the `argus.admin.session` HttpOnly cookie minted by
#               POST /api/v1/auth/admin/login. The /admin/login page is enabled.
#   - auto    : (default) try `session` first; on 401 fall back to `cookie` shim.
#               Lets a fresh dev environment work without provisioning bcrypt
#               admin users while still honouring real sessions when present.
# Production MUST set NEXT_PUBLIC_ADMIN_AUTH_MODE=session and the backend
# ADMIN_AUTH_MODE=session.
# NEXT_PUBLIC_ADMIN_AUTH_MODE=auto

# Optional Playwright E2E: UUID for stable /admin/tenants/{id}/scopes (admin-console.spec.ts).
# E2E_TENANT_ID=
ADMIN_API_KEY=change-me