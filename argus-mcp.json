{
  "mcpServers": {
    "argus": {
      "command": "python",
      "args": [
        "ARGUS/mcp-server/argus_mcp.py",
        "--server",
        "http://127.0.0.1:8000"
      ],
      "env": {
        "ARGUS_SERVER_URL": "http://127.0.0.1:8000",
        "ARGUS_TENANT_ID": "",
        "ARGUS_API_KEY": "",
        "ARGUS_ADMIN_KEY": "",
        "MCP_TRANSPORT": "stdio"
      },
      "description": "ARGUS MCP — HTTP-клиент к backend /api/v1: сканы (create_scan, intelligent_smart_scan, skill), findings/reports/intelligence/sandbox, Kali registry + KAL. Recon: engagements (list/create/get/patch/activate/complete), targets/jobs/artifacts, нормализованные findings, threat-modeling runs, vulnerability-analysis (readiness, evidence, gates), exploitation (status, results, approvals), пути как в /api/v1/recon/…. Отчёт: get_report + download_report → GET /api/v1/reports/{id}/download (report_format, base64 или redirect_url). Admin (X-Admin-Key / ARGUS_ADMIN_KEY): tenants list/create/get, users, subscriptions, providers list + patch, policies, audit-logs, usage, health/dashboard. Кэш: get_cache_stats, get_cache_health, warm_cache, flush_cache. Knowledge: get_knowledge_strategy.",
      "timeout": 300,
      "alwaysAllow": [
        "admin_get_tenant",
        "admin_health_dashboard",
        "admin_list_audit_logs",
        "admin_list_policies",
        "admin_list_providers",
        "admin_list_subscriptions",
        "admin_list_tenants",
        "admin_list_usage",
        "admin_list_users",
        "download_report",
        "get_adversarial_top",
        "get_available_skills",
        "get_cache_health",
        "get_cache_stats",
        "get_engagement",
        "get_exploitation_results",
        "get_exploitation_status",
        "get_finding_detail",
        "get_finding_remediation",
        "get_findings_statistics",
        "get_knowledge_strategy",
        "get_normalized_finding",
        "get_poc_code",
        "get_process_list",
        "get_recon_artifact_download_url",
        "get_recon_artifact_metadata",
        "get_recon_job",
        "get_recon_target",
        "get_report",
        "get_scan_cost",
        "get_scan_memory_summary",
        "get_scan_status",
        "get_scan_timeline",
        "get_threat_model_ai_traces",
        "get_threat_model_input_bundle",
        "get_threat_model_mcp_traces",
        "get_va_confirmed_findings",
        "get_va_evidence_bundles",
        "get_va_evidence_sufficiency",
        "get_va_next_phase_gate",
        "get_vulnerability_analysis_readiness",
        "list_engagement_artifacts",
        "list_engagement_jobs",
        "list_engagement_targets",
        "list_engagements",
        "list_exploitation_approvals",
        "list_findings",
        "list_normalized_findings",
        "list_scans",
        "warm_cache"
      ]
    }
  }
}
