# ARGUS Infrastructure — example env (copy to .env)
# See ARGUS/docs/deployment.md for environment variable reference
#
# ENV FILE LOCATION:
#   .env must be in infra/ (next to docker-compose.yml)
#   Copy: copy infra\.env.example infra\.env  (Windows)
#         cp infra/.env.example infra/.env    (Unix)
#
# SECURITY: Use placeholders only. Production MUST override with strong secrets.
#   Generate: openssl rand -hex 32

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_DB=argus
POSTGRES_USER=argus
# REQUIRED — generate: openssl rand -hex 32
POSTGRES_PASSWORD=argus
# Host-only port for tools (psql, IDE). Containers still use postgres:5432 inside the network.
# Windows + Hyper-V: port range 5341-5440 is often excluded (includes 5432 and 5433). Check with:
#   netsh interface ipv4 show excludedportrange protocol=tcp
# Set a port outside those ranges (e.g. 15432).
POSTGRES_PORT=15432

# =============================================================================
# Redis
# =============================================================================
REDIS_PORT=6379
# When set, redis uses --requirepass. Set REDIS_URL and CELERY_BROKER_URL accordingly.
# Empty = no auth (dev). Use strong password in production (openssl rand -hex 32).
# REQUIRED — generate: openssl rand -hex 32
REDIS_PASSWORD=argussecret
# With auth: redis://:PASSWORD@redis:6379/0
# Without auth: redis://redis:6379/0
# REQUIRED — redis://:YOUR_REDIS_PASSWORD@redis:6379/0
REDIS_URL=redis://:argussecret@redis:6379/0
CELERY_BROKER_URL=redis://:argussecret@redis:6379/0

# =============================================================================
# MinIO (S3-compatible)
# =============================================================================
# --- S3 API (host): http://127.0.0.1:${MINIO_PORT}  |  Web Console: http://127.0.0.1:${MINIO_CONSOLE_PORT} ---
#     Username  = MINIO_ACCESS_KEY
#     Password  = MINIO_SECRET_KEY
#     Windows: if bind fails on 9001, Hyper-V may reserve 8985-9084. Use MINIO_CONSOLE_PORT=12701 (or check: netsh interface ipv4 show excludedportrange protocol=tcp).
# REQUIRED — set unique credentials; do NOT use compose defaults (argus / argussecret) in production.
# Not postgres: this is a separate login/password pair for MinIO/S3 only.
# REQUIRED — unique MinIO access key (never use default 'argus')
MINIO_ACCESS_KEY=argussecret
# REQUIRED — generate: openssl rand -hex 32
MINIO_SECRET_KEY=argussecret
MINIO_BUCKET=argus
# Report exports (RPT-002); created by minio-init alongside MINIO_BUCKET
MINIO_REPORTS_BUCKET=argus-reports
MINIO_ENDPOINT=minio:9000
# Host port published for MinIO S3 API (→ container 9000). On Windows 8985-9084 is often reserved; use e.g. 19000.
MINIO_PORT=19000
# Host port for MinIO Web Console (→ container 9001). Use 12701 if 9001 fails to bind on Windows.
MINIO_CONSOLE_PORT=12701
# Public URL for presigned links in reports (replaces internal Docker hostname).
# Set to the externally-accessible MinIO URL in production (e.g. https://storage.example.com).
# When unset, presigned URLs keep the internal endpoint (dev mode).
# MINIO_PUBLIC_URL=https://storage.example.com

# =============================================================================
# Database URL (backend)
# Built from POSTGRES_* when not set; override for custom connection
# =============================================================================
# DATABASE_URL=postgresql+asyncpg://user:pass@postgres:5432/dbname
# REQUIRED — postgresql+asyncpg://USER:PASSWORD@postgres:5432/argus
DATABASE_URL=postgresql+asyncpg://argus:change-me@postgres:5432/argus

# =============================================================================
# Auth & Security
# =============================================================================
# JWT signing secret; use openssl rand -hex 32 in production
# REQUIRED — generate: openssl rand -hex 32
JWT_SECRET=dev-secret-change-in-prod-32chars
# Admin API keys (X-Admin-Key header for /api/v1/admin/*)
# When ADMIN_API_KEY is unset, admin endpoints return 503 (disabled by design).
# REQUIRED — generate: openssl rand -hex 32
ADMIN_API_KEY=change-me
# Comma-separated API keys accepted via X-API-Key header for scan/data endpoints.
# Env: ARGUS_API_KEYS or API_KEYS (both supported).
# REQUIRED — comma-separated; generate each: openssl rand -hex 32
ARGUS_API_KEYS=change-me
# Nginx gateway auth header injection: key forwarded as X-API-Key to backend for
# /api/* proxy requests (keeps key out of browser code while allowing public UI).
# Use ONE key value (not a comma list). Recommended: dedicated low-privilege key.
ARGUS_GATEWAY_API_KEY=change-me
# Bearer token for /metrics (Prometheus scrape). When unset, /metrics returns 404 (hidden).
# Generate: openssl rand -hex 32
# DANGER: enables login bypass for ANY credentials. NEVER use in production.
# Requires DEBUG=true to have any effect.
DEV_LOGIN_BYPASS_ENABLED=false
METRICS_TOKEN=

# =============================================================================
# LLM Provider Keys (at least one required for AI features)
# =============================================================================
# Routing: each task tries its preferred provider first, then any key from the
# universal chain (not already used by that task): OPENROUTER → KIMI → PERPLEXITY
# → OPENAI → DEEPSEEK → GOOGLE (Gemini). Missing keys are skipped; auth/network
# errors try the next provider. Set any one valid key to run scans that need LLM.
# SECURITY: placeholders only — never commit real keys; use secrets manager in prod
OPENROUTER_API_KEY=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
KIMI_API_KEY=sk-NafWBWngRMJEvjdETZqQ2HpZLe8keE8kmxUS8CqkEuvdpw8Q
PERPLEXITY_API_KEY=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
OPENAI_API_KEY=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
DEEPSEEK_API_KEY=sk-a88b3ae1ead94819bfbce248e44c7339
GOOGLE_API_KEY=AIzaSyAJHX72r0QHeJg15FjtSyM8k6JiVvJVpDU

# Intel adapters (Phase 6) — optional (SHODAN_API_KEY is set in LLM Provider Keys above)
SHODAN_API_KEY=TKQUyfF6hozoSlopRyy7HTpHy0HN69Ee
GITHUB_TOKEN=
CENSYS_API_KEY=censys_WraC1AWM_J6aksENpFVMAqijhRgSar6v7

NVD_API_KEY=
EXPLOITDB_API_KEY=
SECURITYTRAILS_API_KEY=
VIRUSTOTAL_API_KEY=233294f517a816d4f4d79f34ec80a648b666ec34d2b2ad2fadcca1c2fed76ed6
URLSCAN_API_KEY=
ABUSEIPDB_API_KEY=f25f76e2b14d0c508c4bbdc8af47f9bdf4178a09144e84c010cef869dd5304859344af70c13a3be5
GREYNOISE_API_KEY=
OTX_API_KEY=

# =============================================================================
# Application
# =============================================================================
# CORS — backend FastAPI (exact-match list, comma-separated).
# Use this for the production URL and any explicitly pinned preview URLs.
CORS_ORIGINS=https://argus-frontend.vercel.app
CORS_INCLUDE_DEV_ORIGINS=true
# CORS regex — ONE PCRE pattern matching ephemeral origins (Vercel previews,
# Netlify branch deploys, Render PRs). Without it every preview redeploy
# requires editing CORS_ORIGINS and recreating the backend container.
# Vercel preview URL anatomy:
#   https://<project>-<commit-hash>-<org-name>-projects-<team-id>.vercel.app
# Replace `argus-frontend` / `alexds-projects` / `<id>` with YOUR values
# (find them in any Vercel preview URL).
CORS_ORIGIN_REGEX=^https://argus-frontend(-[a-z0-9]+)?-alexds-projects-[a-z0-9]+\.vercel\.app$
# Vercel production URL (no trailing slash) — promoted deploy.
VERCEL_FRONTEND_URL=https://argus-frontend.vercel.app
# Cloudflare Tunnel (optional). Used only with: docker compose --profile tunnel up
# Obtain the JWT only from your Cloudflare Zero Trust account (do not invent a token):
#   Zero Trust → Networks → Tunnels → select tunnel → Install connector / Docker —
#   copy the token from the command: cloudflared tunnel run --token <JWT>
# Leave empty if you do not use the tunnel profile. Placeholder REPLACE_ME is rejected by the entrypoint.
# Compose sets TUNNEL_TOKEN=${CLOUDFLARE_TUNNEL_TOKEN} for the cloudflared service; the wrapper runs:
#   cloudflared tunnel --no-autoupdate run --token <JWT>
# If the token is empty/missing: "cloudflared tunnel run" requires the ID or name of the tunnel
#CLOUDFLARE_TUNNEL_TOKEN=<JWT_FROM_CLOUDFLARE_ZERO_TRUST_DASHBOARD>
LOG_LEVEL=INFO
BACKEND_PORT=8000
# MCP HTTP server (mcp-server Docker / local): avoids clashing with backend :8000
ARGUS_MCP_PORT=8765
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# =============================================================================
# Backend MCP server (Backlog/dev1_md §13 — src.mcp.server). The legacy
# standalone "mcp-server" container reuses ARGUS_MCP_PORT above; the in-process
# FastMCP exposed by `python -m src.mcp.server` honours the MCP_* vars below.
# =============================================================================
# Transport: stdio (default; for IDE / CLI clients) | streamable-http | sse
MCP_TRANSPORT=stdio
# Bind host / port for HTTP transports. Loopback by default — front with an
# auth proxy (Nginx + JWT, Cloudflare Access, etc.) before exposing publicly.
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8765
# Display name & log level
MCP_SERVER_NAME=argus
MCP_LOG_LEVEL=INFO
# Static bearer token accepted on every transport. Generate: openssl rand -hex 32.
# Leave empty to disable static-token auth (JWT / API-key still work).
# REQUIRED for production HTTP/SSE deployments — the stdio fallback only kicks
# in when `MCP_TRANSPORT=stdio` AND no bearer / API-key headers are present.
MCP_AUTH_TOKEN=
# Force authentication on every call regardless of transport. Default: true for
# HTTP/SSE, false for stdio. Set to "true" to require credentials even when the
# server is spawned over stdio (e.g. from an untrusted IDE plugin).
MCP_REQUIRE_AUTH=false
# Default tenant attached to anonymous stdio sessions (must be a valid UUID
# resolvable by the policy plane). Production: set to a dedicated low-privilege
# tenant or disable stdio entirely by deleting MCP_AUTH_TOKEN and using JWT.
MCP_STDIO_TENANT_ID=00000000-0000-0000-0000-000000000001
# Optional override for the actor id used in audit rows when stdio fallback
# kicks in. Defaults to "local-stdio".
MCP_STDIO_ACTOR_ID=local-stdio
# Path to the signed MCP server config (verified at server boot via mcp_sign).
MCP_CONFIG_PATH=backend/config/mcp/server.yaml
MCP_CONFIG_SIGNATURES_PATH=backend/config/mcp/SIGNATURES
MCP_CONFIG_KEYS_DIR=backend/config/mcp/_keys

# =============================================================================
# OWASP / VA active scan (backend + worker: same vars in infra/docker-compose.yml)
# =============================================================================
# Lab checklist:
# - SANDBOX_ENABLED=true is required for VA active-scan tools in sandbox.
# - VA_AI_PLAN_ENABLED=true uses LLM planning when API keys are configured.
# - SQLMAP_VA_ENABLED=true enables sqlmap planning, still gated by lab + per-scan approval.
# - OPENAI_API_KEY / DEEPSEEK_API_KEY / other LLM_* must be set in secrets, not committed.
# - VA_EXPLOIT_AGGRESSIVE_ENABLED=true allows aggressive exploit enqueue when policy allows it.
# - ACTIVE_SCAN_MAX_CONCURRENT_JOBS / ACTIVE_SCAN_MAX_CAPTURE_BYTES / VA_ACTIVE_SCAN_TOOL_TIMEOUT_SEC tune runtime caps.
# - VA_AGGRESSIVE_SCAN=true adds extra tool flags and expands custom reflected-XSS PoC payload count.
# - VA_CUSTOM_XSS_POC_ENABLED=true runs the httpx reflected-XSS probe after active scan.
SANDBOX_ENABLED=true
ARGUS_SANDBOX_PYTHON_ENABLED=true
# argus-sandbox image (docker compose build args): standard = default; extended adds kali-tools-passwords
SANDBOX_PROFILE=extended
INSTALL_MSF=true
# For dev against script-context XSS labs (e.g. alf.nu-style): VA_AGGRESSIVE_SCAN=true
VA_AGGRESSIVE_SCAN=true
VA_CUSTOM_XSS_POC_ENABLED=true
VA_AI_PLAN_ENABLED=true
SQLMAP_VA_ENABLED=true
VA_EXPLOIT_AGGRESSIVE_ENABLED=true
# Active injection modes are controlled from .env:
# quick | standard | deep | maximum | lab.
# Lab profile: only use for targets you own or have explicit written authorization to test.
# ARGUS_LAB_ALLOWED_TARGETS is a comma-separated target allowlist, not boolean.
# ARGUS_LAB_OPERATOR_ID and ARGUS_LAB_SIGNED_APPROVAL_ID are audit identifiers, not "true".
# ARGUS_KILL_SWITCH_REQUIRED=false; также VA_ACTIVE_SCAN_DRY_RUN=true надо убрать/выключить, 
# иначе это не реальный активный прогон
ARGUS_ACTIVE_INJECTION_MODE=lab
ARGUS_LAB_MODE=true
ARGUS_DESTRUCTIVE_LAB_MODE=true
ARGUS_LAB_ALLOWED_TARGETS=https://glomsoposten.vercel.app,localhost,127.0.0.1
ARGUS_LAB_OPERATOR_ID=local-lab-operator
ARGUS_LAB_SIGNED_APPROVAL_ID=local-lab-approval
ARGUS_KILL_SWITCH_REQUIRED=false
ARGUS_OAST_ENABLED=true
ARGUS_AI_PAYLOAD_CANDIDATES=true
ARGUS_AI_GENERATED_LAB_PAYLOADS=true
ARGUS_ACTIVE_INJECTION_RATE_LIMIT_PER_SEC=180
ARGUS_ACTIVE_INJECTION_TIMEOUT_SEC=600
ARGUS_ACTIVE_INJECTION_MAX_CONCURRENCY=5
# Keep false for real lab execution. true only prepares/records dry-run artifacts where supported.
VA_ACTIVE_SCAN_DRY_RUN=false
AI_TEXT_EXECUTIVE_FACT_CHECK_REPLACE=true
# VA_POC_PLAYWRIGHT_SCREENSHOT_ENABLED — Playwright PNG + snippet for confirmed XSS / open redirect.
# VA_POC_PLAYWRIGHT_SCREENSHOT=0|off|false|no — force disable even when ENABLED=true.
VA_POC_PLAYWRIGHT_SCREENSHOT_ENABLED=true
VA_POC_PLAYWRIGHT_SCREENSHOT=100
ACTIVE_SCAN_MAX_CONCURRENT_JOBS=10
ACTIVE_SCAN_MAX_CAPTURE_BYTES=1024000000
VA_ACTIVE_SCAN_TOOL_TIMEOUT_SEC=300

# KAL-006 (backend): searchsploit from recon versions; optional Trivy fs on collected manifests; HIBP reporting (opt-in)
SEARCHSPLOIT_ENABLED=true
SEARCHSPLOIT_MAX_QUERIES=80
TRIVY_ENABLED=true
HARVESTER_ENABLED=true #— theHarvester in VA (email indicators are masked in the report)
VA_ROBOTS_EXTENDED_PIPELINE=true #— after fetch robots/sitemap: shallow gospider/parsero in sandbox
HIBP_PASSWORD_CHECK_OPT_IN=true

# =============================================================================
# XSS Engine (backend — XSS-006 / src.core.config Settings)
# =============================================================================
# XSS_VERIFICATION_ENABLED — headless Playwright XSS verification (Settings.xss_verification_enabled).
XSS_VERIFICATION_ENABLED=true
# XSS_PLAYWRIGHT_TIMEOUT — Playwright timeout in ms (alias XSS_PLAYWRIGHT_TIMEOUT_MS; Settings.xss_playwright_timeout_ms).
XSS_PLAYWRIGHT_TIMEOUT=5000
# XSS_PAYLOAD_COLLECTION_URL — optional URL returning JSON array of payloads merged into buckets (empty = off).
XSS_PAYLOAD_COLLECTION_URL=https://portswigger.net/web-security/cross-site-scripting/cheat-sheet
# XSS_PAYLOAD_REPOS — comma-separated URLs to fetch or merge external XSS payload lists (optional; empty = none).
XSS_PAYLOAD_REPOS=https://example.com/payloads.txt,https://cdn.example.com/xss-wordlist
# XSS_VERIFICATION_HEADLESS_TIMEOUT — seconds cap for headless (e.g. Playwright) XSS verification steps.
XSS_VERIFICATION_HEADLESS_TIMEOUT=15
# XSS_MAX_PAYLOADS_PER_PARAM — upper bound on payloads tried per HTTP parameter (resource / time limit).
XSS_MAX_PAYLOADS_PER_PARAM=50
# XSS_BROWSER_VERIFICATION_ENABLED — opt-in headless browser confirmation of XSS (off by default; needs browser stack on worker).
XSS_BROWSER_VERIFICATION_ENABLED=true
# XSS_CONTEXT_DETECTION_ENABLED — classify reflection context (HTML/attribute/JS) to pick payloads (default on).
XSS_CONTEXT_DETECTION_ENABLED=true

# =============================================================================
# Nginx (production) — non-conflicting defaults to avoid clashing with host :80/:443
# =============================================================================
ARGUS_HTTP_PORT=8080
ARGUS_HTTPS_PORT=8443
# CORS origins for nginx map block. docker-entrypoint.sh builds the map at
# container start. Two entry kinds (comma-separated):
#   • exact match:  https://app.example.com
#   • PCRE regex:   ~^https://example-[a-z0-9]+\.vercel\.app$  (entry MUST start with `~`)
#
# Replace the regex below with one matching YOUR Vercel project pattern, e.g.:
#   ~^https://<project>(-[a-z0-9]+)?-<org>-projects-<teamid>\.vercel\.app$
# Find your `<org>-projects-<teamid>` segment in any preview URL.
ARGUS_CORS_ALLOWED_ORIGINS=https://argus-frontend.vercel.app,~^https://argus-frontend(-[a-z0-9]+)?-alexds-projects-[a-z0-9]+\.vercel\.app$,http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Stage 4: Exploitation
# =============================================================================
# MinIO bucket for Stage 4 exploitation artifacts (plans, results, shell logs)
STAGE4_ARTIFACTS_BUCKET=stage4-artifacts
# Max duration (minutes) for a single exploitation run before timeout
EXPLOITATION_TIMEOUT_MINUTES=100
# Max concurrent exploitation runs across all engagements
EXPLOITATION_MAX_CONCURRENT=30
# Minutes to wait for manual approval before auto-expiring an exploitation request
EXPLOITATION_APPROVAL_TIMEOUT_MINUTES=600
# =============================================================================
# Intel / Recon Adapters (optional)
# =============================================================================

# =============================================================================
# RECON-001 — recon pipeline (backend / worker)
# =============================================================================
# RECON_MODE=passive|active|full — default full (legacy: all current tools).
# RECON_PASSIVE_ONLY=true #— force passive regardless of RECON_MODE.
# RECON_ACTIVE_DEPTH — reserved for future active sub-steps (integer >= 0).
# RECON_ENABLE_CONTENT_DISCOVERY / RECON_JS_ANALYSIS / RECON_SCREENSHOTS / RECON_DEEP_PORT_SCAN —
#   optional full-mode steps; RECON_DEEP_PORT_SCAN enables RECON-005 (naabu + nmap -sV) when mode=full.
# RECON_TOOL_SELECTION — comma-separated logical step ids (subset of plan); empty = no filter.
# RECON_WORDLIST_PATH — path for future content/dir busting tools.
# RECON_RATE_LIMIT — requests/sec cap for pipeline (overrides RECON_RATE_LIMIT_PER_SECOND when set).
# RECON_RATE_LIMIT_PER_SECOND — legacy default throttle (default 10) when RECON_RATE_LIMIT unset.
RECON_MODE=full
RECON_PASSIVE_ONLY=false
RECON_ACTIVE_DEPTH=1
RECON_ENABLE_CONTENT_DISCOVERY=true
RECON_DEEP_PORT_SCAN=true
RECON_JS_ANALYSIS=true
RECON_SCREENSHOTS=true
RECON_TOOL_SELECTION=url_history,content_discovery,js_analysis,asnmap,screenshots,deep_port_scan
RECON_WORDLIST_PATH=wordlists/subdomains.txt
RECON_RATE_LIMIT=10
RECON_RATE_LIMIT_PER_SECOND=10
# RECON-002 — passive subdomain tools (subfinder, assetfinder, findomain, theHarvester) in sandbox.
# Requires SANDBOX_ENABLED and scan opt-in kal.recon_dns_enumeration_opt_in. Falls back to RECON_TOOLS_TIMEOUT.
RECON_PASSIVE_SUBDOMAIN_TIMEOUT_SEC=300
# theHarvester -b sources (comma-separated; server policy caps allowed names, e.g. crtsh,anubis,urlscan).
RECON_THEHARVESTER_SOURCES=crtsh,anubis,urlscan
RECON_THEHARVESTER_RECON_LIMIT=300
#RECON_THEHARVESTER_PASSIVE_ENABLED=true
# RECON-003 — dnsx A/AAAA/CNAME/MX/TXT/NS (+ optional dig ANY); artifacts dns_records.json + dnsx_raw/dig_depth_raw under recon/raw.
RECON_DNS_DEPTH_ENABLED=true
RECON_DNS_DEPTH_DIG_DEEP=true
RECON_DNS_DEPTH_TAKEOVER_HINTS=true
RECON_DNSX_RECORD_TYPES=a,aaaa,cname,mx,txt,ns
RECON_DNSX_INCLUDE_RESP=true
RECON_DNSX_SILENT=true
RECON_DNS_DEPTH_TIMEOUT_SEC=300
RECON_DNSX_EXTRA_FLAGS=-silent -wd -resp -oc
RECON-004 — httpx / whatweb / nuclei tech recon (active & full)
RECON_NUCLEI_TECH_TAGS=tech
RECON_NUCLEI_TECH_TEMPLATES=templates/nuclei/tech.yaml
# RECON-005 — deep port scan caps (see backend .env.example)
RECON_DEEP_NAABU_ENABLED=true
RECON_DEEP_NAABU_TOP_PORTS=500
RECON_DEEP_MAX_HOSTS=5
RECON_DEEP_MAX_PORTS_PER_HOST=40
RECON_DEEP_TIMEOUT_SEC=
# RECON-007 — query params + JS analysis (full + RECON_JS_ANALYSIS); see backend .env.example for caps / linkfinder / unfurl
RECON_JS_MAX_MERGED_URLS=20000
RECON_JS_MAX_JS_URLS=200
RECON_JS_MAX_DOWNLOADS=15
RECON_JS_MAX_RESPONSE_BYTES=1048576
RECON_JS_LINKFINDER_ENABLED=true
RECON_JS_UNFURL_ENABLED=true
RECON_JS_UNFURL_MAX_URLS=10
#
# RECON-008 — asnmap + gowitness (full + RECON_ASNMAP_ENABLED / RECON_SCREENSHOTS); KAL categories asn_mapping, web_screenshots
RECON_ASNMAP_ENABLED=true
RECON_GOWITNESS_MAX_URLS=25
RECON_GOWITNESS_TIMEOUT_SEC=500
RECON_GOWITNESS_CONCURRENCY=3

# ═══ ENH-V2: Enhancement Module Configuration ═══
# Multi-provider LLM routing: override primary provider for all tasks
# Options: deepseek, openai, openrouter, kimi, perplexity
LLM_PRIMARY_PROVIDER=deepseek

# Maximum LLM cost per scan (USD). Scan aborts if exceeded.
MAX_COST_PER_SCAN_USD=10.0

# Report language (ISO 639-1). AI sections will be generated in this language.
REPORT_LANGUAGE=en

# Shodan enrichment: cross-reference findings with Shodan CVEs and service data
SHODAN_ENRICHMENT_ENABLED=true

# Perplexity web-search intelligence: CVE exploit search, domain OSINT
PERPLEXITY_INTEL_ENABLED=true

# Adversarial prioritization score: compute attack-realistic scoring
ADVERSARIAL_SCORE_ENABLED=true

# Exploitability validation: multi-stage LLM validation pipeline
EXPLOITABILITY_VALIDATION_ENABLED=true

# PoC generation: auto-generate proof-of-concept scripts for confirmed findings
POC_GENERATION_ENABLED=true

# ─── ENH-V3: Strix-based enhancements ───────────────────────────────

# Backend fallback scan mode when a request does not provide scan_mode:
# quick | standard | deep | lab
SCAN_MODE=lab

# LLM-based semantic deduplication of findings (Strix-style XML response)
LLM_DEDUP_ENABLED=true

# Memory compression for long-running scans (>40 LLM calls)
MEMORY_COMPRESSION_ENABLED=true
