# ARGUS Infrastructure — example env (copy to .env)
# See ARGUS/docs/env-vars.md for full reference

# PostgreSQL
POSTGRES_USER=argus
POSTGRES_PASSWORD=argus
POSTGRES_DB=argus
POSTGRES_PORT=5432

# MinIO (S3-compatible)
MINIO_ACCESS_KEY=argus
MINIO_SECRET_KEY=argussecret
MINIO_BUCKET=argus
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Redis
REDIS_PORT=6379

# Backend
BACKEND_PORT=8000
LOG_LEVEL=INFO

# Auth (Phase 2+)
# Required for POST /api/v1/auth/login. Dev placeholder; use openssl rand -hex 32 in production
JWT_SECRET=dev-secret-change-in-prod-32chars
