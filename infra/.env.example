# ARGUS Infrastructure — example env (copy to .env)
# See ARGUS/docs/env-vars.md for full reference
#
# ENV FILE LOCATION:
#   .env must be in infra/ (next to docker-compose.yml)
#   Copy: copy infra\.env.example infra\.env  (Windows)
#         cp infra/.env.example infra/.env    (Unix)
#
# SECURITY: Use placeholders only. Production MUST override with strong secrets.
#   Generate: openssl rand -hex 32

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_DB=argus
POSTGRES_USER=argus
POSTGRES_PASSWORD=argus
POSTGRES_PORT=5432

# =============================================================================
# Redis
# =============================================================================
REDIS_PORT=6379
# When set, redis uses --requirepass. Set REDIS_URL and CELERY_BROKER_URL accordingly.
# Empty = no auth (dev). Use strong password in production (openssl rand -hex 32).
REDIS_PASSWORD=argussecret
# With auth: redis://:PASSWORD@redis:6379/0
# Without auth: redis://redis:6379/0
REDIS_URL=redis://:argussecret@redis:6379/0
CELERY_BROKER_URL=redis://:argussecret@redis:6379/0

# =============================================================================
# MinIO (S3-compatible)
# =============================================================================
# --- Web Console: http://127.0.0.1:9001 (нужен dev/override с портами 9000,9001) ---
#     Username  = MINIO_ACCESS_KEY
#     Password  = MINIO_SECRET_KEY
# Пустые в .env → дефолты compose: argus / argussecret
# Не postgres: это отдельная пара логин/пароль только для MinIO/S3.
MINIO_ACCESS_KEY=argus
MINIO_SECRET_KEY=argussecret
MINIO_BUCKET=argus
# Report exports (RPT-002); created by minio-init alongside MINIO_BUCKET
MINIO_REPORTS_BUCKET=argus-reports
MINIO_ENDPOINT=minio:9000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# =============================================================================
# Database URL (backend)
# Built from POSTGRES_* when not set; override for custom connection
# =============================================================================
# DATABASE_URL=postgresql+asyncpg://user:pass@postgres:5432/dbname
DATABASE_URL=postgresql+asyncpg://argus:change-me@postgres:5432/argus

# =============================================================================
# Auth & Security
# =============================================================================
# JWT signing secret; use openssl rand -hex 32 in production
JWT_SECRET=dev-secret-change-in-prod-32chars
# Admin API keys (X-Admin-Key header for /api/v1/admin/*)
# Backend uses ADMIN_API_KEY; API_KEYS reserved for future multi-key support
API_KEYS=change-me
ADMIN_API_KEY=change-me

# =============================================================================
# LLM Provider Keys (at least one required for AI features)
# =============================================================================
OPENROUTER_API_KEY=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
KIMI_API_KEY=sk-NafWBWngRMJEvjdETZqQ2HpZLe8keE8kmxUS8CqkEuvdpw8Q
PERPLEXITY_API_KEY=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
OPENAI_API_KEY=
# Optional; leave empty if unused
DEEPSEEK_API_KEY=sk-a88b3ae1ead94819bfbce248e44c7339
GOOGLE_API_KEY=
SHODAN_API_KEY=TKQUyfF6hozoSlopRyy7HTpHy0HN69Ee

# Intel adapters (Phase 6) — optional (SHODAN_API_KEY is set in LLM Provider Keys above)
GITHUB_TOKEN=
CENSYS_API_KEY=

NVD_API_KEY=
EXPLOITDB_API_KEY=
SECURITYTRAILS_API_KEY=
VIRUSTOTAL_API_KEY=
URLSCAN_API_KEY=
ABUSEIPDB_API_KEY=
GREYNOISE_API_KEY=
OTX_API_KEY=

# =============================================================================
# Application
# =============================================================================
# CORS: comma-separated origins; merged with localhost dev URLs and VERCEL_FRONTEND_URL
CORS_ORIGINS=https://argus-frontend-d40iwi10b-alexds-projects-110e6fa8.vercel.app
# Vercel app URL (no trailing slash) — included in CORS allow_origins
VERCEL_FRONTEND_URL=https://argus-frontend-d40iwi10b-alexds-projects-110e6fa8.vercel.app
# Cloudflare Tunnel (optional). Used only with: docker compose --profile tunnel up
# Obtain the JWT only from your Cloudflare Zero Trust account (do not invent a token):
#   Zero Trust → Networks → Tunnels → select tunnel → Install connector / Docker —
#   copy the token from the command: cloudflared tunnel run --token <JWT>
# Leave empty if you do not use the tunnel profile. Placeholder REPLACE_ME is rejected by the entrypoint.
# Compose sets TUNNEL_TOKEN=${CLOUDFLARE_TUNNEL_TOKEN} for the cloudflared service; the wrapper runs:
#   cloudflared tunnel --no-autoupdate run --token <JWT>
# If the token is empty/missing: "cloudflared tunnel run" requires the ID or name of the tunnel
#CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoiMzg5NDhkNWMzMDdmNGUzYjI0NzBkMzZlYzFkMjkwMzEiLCJ0IjoiMTBkNDkxYjUtNDg1MC00MTk0LWI5MDUtOTgwMTI0NjNkNTcxIiwicyI6IllUYzBNalprWlRjdE5tVmtNUzAwTVRJMUxUazJZekl0TkROa1pETTFNamN4T0RFeSJ9
LOG_LEVEL=INFO
BACKEND_PORT=8000
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
SANDBOX_ENABLED=True

# =============================================================================
# Nginx (production)
# =============================================================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# =============================================================================
# Stage 4: Exploitation
# =============================================================================
# MinIO bucket for Stage 4 exploitation artifacts (plans, results, shell logs)
STAGE4_ARTIFACTS_BUCKET=stage4-artifacts
# Max duration (minutes) for a single exploitation run before timeout
EXPLOITATION_TIMEOUT_MINUTES=100
# Max concurrent exploitation runs across all engagements
EXPLOITATION_MAX_CONCURRENT=30
# Minutes to wait for manual approval before auto-expiring an exploitation request
EXPLOITATION_APPROVAL_TIMEOUT_MINUTES=600
# =============================================================================
# Intel / Recon Adapters (optional)
# =============================================================================

